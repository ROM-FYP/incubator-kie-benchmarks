package ats.surveillance.stca.prototype

import java.lang.Math;
i:contentReference[oaicite:39]{index=39}java.util.ArrayList;

dialect "java"

/**
 * DATA MODEL (OpenSky /states/all)
 * Fields per state vector: icao24, callsign, :contentReference[oaicite:40]{index=40}, last_contact,
 * lon, lat, baro_altitude(m), on_ground, velocity(m/s), true_track(deg), vertical_rate(m/s),
 * sensors, geo_altitude(m), squawk, spi, position_source, category
 * Source: OpenSky REST API docs. (Used by your collector before rules fire.)  :contentReference[oaicite:41]{index=41}
 */

/* -----------------------------
   FUNCTIONS / CONSTANTS
   ----------------------------- */

global double NOW_EPOCH_SEC; // set by host each cycle (snapshot time)

function double nm(double meters){ return meters / 1852.0; }
function double metersFromNm(double nm){ return nm * 1852.0; }

function double haversineMeters(double lat1, double lon1, double lat2, double lon2){
    double R = 6371000.0;
    double dLat = Math.toRadians(lat2-lat1);
    double dLon = Math.toRadians(lon2-lon1);
    double a = Math.sin(dLat/2)*Math.sin(dLat/2) +
               Math.cos(Math.toRadians(lat1))*Math.cos(Math.toRadians(lat2)) *
               Math.sin(dLon/2)*Math.sin(dLon/2);
    double c = 2.0 * Math.atan2(Math.sqrt(a), Math.sqrt(1.0-a));
    return R*c;
}

/** Very simple CPA approximation (flat-earth-ish in meters) for short horizons */
function double timeToCpaSec(double dx, double dy, double dvx, double dvy){
    double dv2 = dvx*dvx + dvy*dvy;
    if(dv2 < 1e-6) return Double.POSITIVE_INFINITY;
    double t = - (dx*dvx + dy*dvy) / dv2;
    return t;
}

/* -----------------------------
   DECLARES
   ----------------------------- */

declare StateVector
    icao24         : String
    callsign       : String
    lat            : Double
    lon            : Double
    baroAltM       : Double
    geoAltM        : Double
    onGround       : Boolean
    velMps         : Double
    trackDeg       : Double
    vrtMps         : Double
    timePosition   : Long
    lastContact    : Long
    squawk         : String
    spi            : Boolean
    category       : Integer
end

declare TrackQuality
    icao24     : String
    stalePos   : Boolean
    staleAny   : Boolean
    missingPos : Boolean
    badAlt     : Boolean
    badVel     : Boolean
    reason     : String
end

declare KinematicDelta
    icao24   : String
    dVel     : Double
    dTrack   : Double
    dVrt     : Double
    dtSec    : Double
end

declare GridCell
    cellId : String
    icao24 : String
end

declare PairCandidate
    a : String
    b : String
    cellId : String
end

declare ConflictCandidate
    a : String
    b : String
    distM : Double
    vertSepM : Double
    closing : Boolean
    ttcSec : Double
    severity : String  // INFO/WARN/ALERT
end

declare AlertInhibit
    kind : String // "AIRSPACE" or "FLIGHTPAIR" or "FLIGHT"
    key  : String // your encoding: cellId, icao24, or "a|b"
    enabled : Boolean
end

declare Alert
    a : String
    b : String
    type : String // STCA_LIKE, TRAFFIC_ADVISORY, SAFETY_ALERT
    severity : String
    createdAt : Double
    reason : String
end

declare AlertAck
    key : String // "a|b|type"
    at  : Double
end

declare Status
    stcaAvailable : Boolean
    at : Double
end

declare AuditEvent
    kind : String
    key  : String
    at   : Double
    details : String
end

/* -----------------------------
   PARAMETERS (tune per airspace)
   -----------------------------
   - STCA expects warning time sufficient when geometry permits; and nuisance/false alerts minimized.
     :contentReference[oaicite:42]{index=42}
   - FAA radar minima: terminal 3NM (<40mi) / 5NM etc; used here as prototype thresholds.
     :contentReference[oaicite:43]{index=43}
*/

declare Params
    gridDeg       : Double  // grid size for join reduction
    stalePosSec   : Long
    staleAnySec   : Long
    nearDistNm    : Double
    warnDistNm    : Double
    alertDistNm   : Double
    vertMinFt     : Double
    warnTt:contentReference[oaicite:44]{index=44}Sec   : Double
    persistSec    : Double
end

/* ===========================
   Option B facts (inserted by ingestion)
   =========================== */
declare CpaMetrics
    a              : String
    b              : String
    computedAtSec  : Double
    tCpaSec        : Double   // time to closest point of approach
    dCpaM          : Double   // horizontal distance at CPA
    vertAtCpaM     : Double   // predicted vertical separation at CPA
    closing        : Boolean
end

declare PairRiskState
    key            : String   // "a|b"
    lastAtSec      : Double
    warnStreak     : int
    alertStreak    : int
    safeStreak     : int
end

rule "R000_LoadDefaultParams"
salience 1000
when
:contentReference[oaicite:45]{index=45}ert(new Params(0.25, 20L, 30L, 10.0, 5.0, 3.0, 1000.0, 90.0, 45.0, 15.0));
end


/* ============================================================
   TRACK / DATA QUALITY RULES (R001–R020)
   Semantics: reduce false/nuisance alerts; STCA requires both minimized.
   :contentReference[oaicite:46]{index=46} :contentReference[oaicite:47]{index=47}
   ============================================================ */

rule "R001_MissingPositionFlag"
when
    $s : StateVector( lat == null || lon == null )
then
    insert(new TrackQuality($s.getIcao24(), false,false,true,false,false,"missing lat/lon"));
end

rule "R002_StalePositionFlag"
when
    $p : Params()
    $s : StateVector( timePosi:contentReference[oaicite:48]{index=48}C:contentReference[oaicite:49]{index=49}osSec )
then
    insert(new TrackQuality($s.getIcao24(), true,false,false,false,false,"stale position"));
end

rule "R003_StaleContactFlag"
when
    $p : Params()
    $s : StateVector( lastContact == null || (NOW_EPOCH_SEC - lastContact) > $p.staleAnySec )
then
    insert(new TrackQuality($s.getIcao24(), false,true,false,false,false,"stale last_contact"));
end

rule "R004_BadAltitudeFlag"
when
    $s : StateVector( (baroAltM != null && baroAltM < -200) || (geoAltM != null && geoAltM < -200) )
then
    insert(new TrackQuality($s.getIcao24(), false,false,false,true,false,"negative altitude"));
end

rule "R005_BadVelocityFlag"
when
    $s : StateVector( velMps != null && velMps < 0 )
then
    insert(new TrackQuality($s.getIcao24(), false,false,false,false,true,"negative velocity"));
end

rule "R006_OnGroundButHighSpeed"
when
    $s : StateVector( onGround == true, velMps != null && velMps > 120 )
then
    insert(new AuditEvent("DATA_ANOMALY", $s.getIcao24(), NOW_EPOCH_SEC, "onGround true but high speed"));
end

rule "R007_MissingCallsignAudit"
when
    $s : StateVector( callsign == null )
then
    insert(new AuditEvent("DATA_QUALITY", $s.getIcao24(), NOW_EPOCH_SEC, "callsign missing"));
end

rule "R008_SquawkSpecialPurposeAudit"
when
    $s : StateVector( squawk != null, spi == true )
then
    insert(new AuditEvent("SURVEILLANCE", $s.getIcao24(), NOW_EPOCH_SEC, "SPI set with squawk="+$s.getSquawk()));
end

rule "R009_FilterTracksMissingPositionFromPairing"
when
    $s : StateVector()
    TrackQuality( icao24 == $s.icao24, missingPos == true )
then
    // do nothing: this rule exists to document filtering intent
end

rule "R010_FilterStalePositionFromPairing"
when
    $s : StateVector()
    TrackQuality( icao24 == $s.icao24, stalePos == true )
then
end

rule "R011_FilterBadVelocityFromPairing"
when
    $s : StateVector()
    TrackQuality( icao24 == $s.icao24, badVel == true )
then
end

rule "R012_FilterBadAltitudeFromPairing"
when
    $s : StateVector()
    TrackQuality( icao24 == $s.icao24, badAlt == true )
then
end

rule "R013_DataQualitySummaryEvent"
when
    $q : TrackQuality()
then
    insert(new AuditEvent("TRACK_QUALITY", $q.getIcao24(), NOW_EPOCH_SEC, $q.getReason()));
end

rule "R014_StalePosClearsOldAlerts"
when
    $q : TrackQuality( stalePos == true )
    $a : Alert( (a == $q.icao24 || b == $q.icao24) )
then
    retract($a);
end

rule "R015_StaleContactClearsOldAlerts"
when
    $q : TrackQuality( staleAny == true )
    $a : Alert( (a == $q.icao24 || b == $q.icao24) )
then
    retract($a);
end

rule "R016_CategoryUnknownAudit"
when
    $s : StateVector( category == null || category == 0 )
then
    insert(new AuditEvent("DATA_QUALITY", $s.getIcao24(), NOW_EPOCH_SEC, "category unknown"));
end

rule "R017_PositionSourceAudit"
when
    $s : StateVector()
then
    // placeholder: position_source useful for tuning false-alert causes (e.g., MLAT/ADS-B mix)
end

rule "R018_TooFastForAltitudeBandAudit"
when
    $s : StateVector( geoAltM != null && geoAltM < 300, velMps != null && velMps > 250 )
then
    insert(new AuditEvent("DATA_ANOMALY", $s.getIcao24(), NOW_EPOCH_SEC, "low altitude but very high speed"));
end

rule "R019_NullAltitudesAudit"
when
    $s : StateVector( baroAltM == null && geoAltM == null )
then
    insert(new AuditEvent("DATA_QUALITY", $s.getIcao24(), NOW_EPOCH_SEC, "both altitudes null"));
end

rule "R020_TrackDegRangeAudit"
when
    $s : StateVector( trackDeg != null && (trackDeg < 0 || trackDeg >= 360) )
then
    insert(new AuditEvent("DATA_ANOMALY", $s.getIcao24(), NOW_EPOCH_SEC, "track out of range"));
end


/* ============================================================
   KINEMATICS / ANOMALY RULES (R021–R040)
   Semantics: monitoring environment as safety net. :contentReference[oaicite:50]{index=50}
   ============================================================ */

rule "R021_DeltaVelocityOver10s"
when
    $s1 : StateVector( $id:icao24, velMps != null, $t1:lastContact )
    $s0 : StateVector( icao24 == $id, this != $s1, velMps != null, $t0:lastContact, $t0 < $t1 )
then
    double dt = ($t1 - $t0);
    if(dt > 0 && dt <= 15){
      insert(new KinematicDelta($id, $s:contentReference[oaicite:51]{index=51}, 0.0, 0.0, dt));
    }
end

rule "R022_SuddenSpeedJumpAudit"
when
    KinematicDelta( $id:icao24, dVel != null && Math.abs(dVel) > 80 )
then
    insert(new AuditEvent("KINEMATICS", $id, NOW_EPOCH_SEC, "sudden speed jump"));
end

rule "R023_SuddenVerticalRateAudit"
when
    $s : StateVector( vrtMps != null && Math.abs(vrtMps) > 40 )
then
    insert(new AuditEvent("KINEMATICS", $s.getIcao24(), NOW_EPOCH_SEC, "extreme vertical rate"));
end

rule "R024_SuddenTurnRateApproxAudit"
when
    $s1 : StateVector( $id:icao24, trackDeg != null, $t1:lastContact )
    $s0 : StateVector( icao24 == $id, this != $s1, trackDeg != null, $t0:lastContact, $t0 < $t1 )
then
    double dt = ($t1 - $t0);
    if(dt > 0 && dt <= 15){
      double d = Math.abs($s1.getTrackDeg()-$s0.getTrackDeg());
      if(d > 180) d = 360-d;
      if(d/dt > 10) insert(new AuditEvent("KINEMATICS", $id, NOW_EPOCH_SEC, "high turn rate approx"));
    }
end

rule "R025_AltitudeJumpAudit"
when
    $s1 : StateVector( $id:icao24, geoAltM != null, $t1:lastContact )
    $s0 : StateVector( icao24 == $id, this != $s1, geoAltM != null, $t0:lastContact, $t0 < $t1 )
then
    double dt = ($t1 - $t0);
    if(dt > 0 && dt <= 15){
      if(Math.abs($s1.getGeoAltM()-$s0.getGeoAltM()) > 1200) insert(new AuditEvent("KINEMATICS", $id, NOW_EPOCH_SEC, "altitude jump"));
    }
end

rule "R026_OnGroundStateFlipAudit"
when
    $s1 : StateVector( $id:icao24, $g1:onGround, $t1:lastContact )
    $s0 : StateVector( icao24 == $id, this != $s1, $g0:onGround, $t0:lastContact, $t0 < $t1 )
    eval($g0 != $g1 && ($t1-$t0) <= 15)
then
    insert(new AuditEvent("KINEMATICS", $id, NOW_EPOCH_SEC, "onGround flip"));
end

rule "R027_UnknownVelButMovingAudit"
when
    $s : StateVector( velMps == null, onGround == false )
then
    insert(new AuditEvent("DATA_QUALITY", $s.getIcao24(), NOW_EPOCH_SEC, "airborne but velocity null"));
end

rule "R028_UnknownTrackButMovingAudit"
when
    $s : StateVector( trackDeg == null, velMps != null && velMps > 30 )
then
    insert(new AuditEvent("DATA_QUALITY", $s.getIcao24(), NOW_EPOCH_SEC, "moving but track null"));
end

rule "R029_ClimbWhileOnGroundAudit"
when
    $s : StateVector( onGround == true, vrtMps != null && Math.abs(vrtMps) > 3 )
then
    insert(new AuditEvent("DATA_ANOMALY", $s.getIcao24(), NOW_EPOCH_SEC, "vertical rate while on ground"));
end

rule "R030_BaroGeoDisagreeAudit"
when
    $s : StateVector( baroAltM != null, geoAltM != null, Math.abs(baroAltM-geoAltM) > 600 )
then
    insert(new AuditEvent("DATA_ANOMALY", $s.getIcao24(), NOW_EPOCH_SEC, "baro vs geo altitude disagree"));
end

rule "R031_SlowHoveringRotorcraftAudit"
when
    $s : StateVector( category == 8, velMps != null && velMps < 10, onGround == false )
then
    insert(new AuditEvent("OPS_PATTERN", $s.getIcao24(), NOW_EPOCH_SEC, "rotorcraft low speed airborne"));
end

rule "R032_UAVAudit"
when
    $s : StateVector( category == 14 )
then
    insert(new AuditEvent("OPS_PATTERN", $s.getIcao24(), NOW_EPOCH_SEC, "UAV category"));
end

rule "R033_GliderAudit"
when
    $s : StateVector( category == 9 )
then
    insert(new AuditEvent("OPS_PATTERN", $s.getIcao24(), NOW_EPOCH_SEC, "glider category"));
end

rule "R034_EmergencyVehicleAudit"
when
    $s : StateVector( category == 16 )
then
    insert(new AuditEvent("OPS_PATTERN", $s.getIcao24(), NOW_EPOCH_SEC, "surface emergency vehicle category"));
end

rule "R035_PointObstacleAudit"
when
    $s : StateVector( category == 18 )
then
    insert(new AuditEvent("OPS_PATTERN", $s.getIcao24(), NOW_EPOCH_SEC, "point obstacle category"));
end

rule "R036_SquawkChangedAudit"
when
    $s1 : StateVector( $id:icao24, squawk != null, $sq1:squawk, $t1:lastContact )
    $s0 : StateVector( icao24 == $id, this != $s1, squawk != null, $sq0:squawk, $t0:lastContact, $t0 < $t1 )
    eval(!$sq0.equals($sq1) && ($t1-$t0)<=60)
then
    insert(new AuditEvent("SURVEILLANCE", $id, NOW_EPOCH_SEC, "squawk changed "+$sq0+"->"+$sq1));
end

rule "R037_SpiSetAudit"
when
    $s : StateVector( spi == true )
then
    insert(new AuditEvent("SURVEILLANCE", $s.getIcao24(), NOW_EPOCH_SEC, "SPI set"));
end

rule "R038_CallsignWhitespaceAudit"
when
    $s : StateVector( callsign != null && callsign.trim().length() == 0 )
then
    insert(new AuditEvent("DATA_QUALITY", $s.getIcao24(), NOW_EPOCH_SEC, "callsign blank"));
end

rule "R039_OriginCountryPresentAudit"
when
    $s : StateVector()
then
    // placeholder: origin_country can be tracked for analytics; not used in safety logic
end

rule "R040_KinematicsReady"
when
    $s : StateVector( lat != null, lon != null, onGround == false )
then
    // marker rule; nothing to do
end


/* ============================================================
   GRID / PAIR CANDIDATES (R041–R055)
   Join-heavy optimization: make pairs only within same grid cell.
   ============================================================ */

rule "R041_AssignGridCell"
when
    $p : Params()
    $s : StateVector( lat != null, lon != null )
then
    int gx = (int)Math.floor($s.getLat() / $p.getGridDeg());
    int gy = (int)Math.floor($s.getLon() / $p.getGridDeg());
    insert(new GridCell(gx+"_"+gy, $s.getIcao24()));
end

rule "R042_PairWithinCell"
when
    $c1 : GridCell( $cell:cellId, $a:icao24 )
    $c2 : GridCell( cellId == $cell, $b:icao24, this != $c1 )
    eval($a.compareTo($b) < 0)
then
    insert(new PairCandidate($a, $b, $cell));
end

rule "R043_NoPairIfSameAircraft"
when
    PairCandidate( a == b )
then
    // should never happen
end

rule "R044_PairInhibitByCell"
when
    $pc : PairCandidate( $cell:cellId )
    AlertInhibit( kind == "AIRSPACE", key == $cell, enabled == true )
then
    retract($pc);
end

rule "R045_PairInhibitByFlight"
when
    $pc : PairCandidate( $a:a )
    AlertInhibit( kind == "FLIGHT", key == $a, enabled == true )
then
    retract($pc);
end

rule "R046_PairInhibitByFlightB"
when
    $pc : PairCandidate( $b:b )
    AlertInhibit( kind == "FLIGHT", key == $b, enabled == true )
then
    retract($pc);
end

rule "R047_PairInhibitByPairKey"
when
    $pc : PairCandidate( $a:a, $b:b )
    AlertInhibit( kind == "FLIGHTPAIR", key == ($a+"|"+$b), enabled == true )
then
    retract($pc);
end

rule "R048_SkipOnGroundPairs"
when
    $pc : PairCandidate( $a:a, $b:b )
    StateVector( icao24 == $a, onGround == true )
    StateVector( icao24 == $b, onGround == true )
then
    retract($pc);
end

rule "R049_SkipIfAnyTrackQualityBad"
when
    $pc : PairCandidate( $a:a, $b:b )
    ( TrackQuality( icao24 == $a, (missingPos==true || stalePos==true || badAlt==true || badVel==true) )
      or
      TrackQuality( icao24 == $b, (missingPos==true || stalePos==true || badAlt==true || badVel==true) ) )
then
    retract($pc);
end

rule "R050_PairCandidateAudit"
when
    $pc : PairCandidate()
then
    // optional: insert AuditEvent("PAIR", $pc.a+"|"+$pc.b, NOW_EPOCH_SEC, $pc.cellId);
end

rule "R051_PairDedupGuard"
when
    $pc : PairCandidate( $k: (a+"|"+b) )
    PairCandidate( this != $pc, (a+"|"+b) == $k )
then
    retract($pc);
end

rule "R052_PairCandidateReady"
when
    $pc : PairCandidate()
then
end

rule "R053_ClearGridCellsEachCycle"
when
    $g : GridCell()
then
    retract($g);
end

rule "R054_ClearPairCandidatesEachCycle"
when
    $pc : PairCandidate()
then
    // keep for conflict computation rules in same cycle; host can clear after firing if needed
end

rule "R055_ClearKinematicDeltaEachCycle"
when
    $d : KinematicDelta()
then
    retract($d);
end


/* ============================================================
   CONFLICT DETECTION (R056–R080)
   STCA definition: conflict is predicted violation of separation minima. :contentReference[oaicite:52]{index=52}
   Warning time + continued alert while conditions exist. :contentReference[oaicite:53]{index=53}
   ============================================================ */

rule "R056_BuildConflictCandidateBasic"
when
    $p : Params()
    $pc : PairCandidate( $a:a, $b:b )
    $sa : StateVector( icao24 == $a, lat != null, lon != null, velMps != null, trackDeg != null,
                    :contentReference[oaicite:54]{index=54}vel:velMps, $atrk:trackDeg,
                       $aa: (ge:contentReference[oaicite:55]{index=55}oAltM) )
    $sb : StateVector( icao24 == $b, lat != null, lon != null, velMps != null, trackDeg != null,
                       $blat:lat, $blon:lon, $bvel:velMps, $btrk:trackDeg,
                       $ba: (geoAltM != null ? geoAltM : baroAltM) )
then
    double d = haversineMeters($alat,$alon,$blat,$blon);
    double vert = ( ($aa!=null && $ba!=null) ? Math.abs($aa-$ba) : Double.NaN );

    // crude closing test using range rate approx: if both have valid velocity, assume closing if within near band
    boolean closing = d < metersFromNm($p.nearDistNm);

    // TTC placeholder: without converting to XY, use distance / relative speed magnitude approx
    double rel = Math.abs($avel - $bvel);
    double ttc = (rel > 1.0) ? (d / rel) : Double.POSITIVE_INFINITY;

    String sev = "INFO";
    if(d <= metersFromNm($p.warnDistNm) || ttc <= $p.warnTtcSec) sev = "WARN";
    if(d <= metersFromNm($p.alertDistNm) || ttc <= $p.alertTtcSec) sev = "ALERT";

    insert(new ConflictCandidate($a,$b,d,vert,closing,ttc,sev));
end

rule "R057_DowngradeIfVerticalSeparationLarge"
when
    $p : Params()
    $c : ConflictCandidate( vertSepM == vertSepM, vertSepM > ( ($p.vertMinFt*0.3048) * 2.0 ), severity != "INFO" )
then
    modify($c){ setSeverity("INFO"); }
end

rule "R058_UpgradeIfVeryClose"
when
    $p : Params()
    $c : ConflictCandidate( distM < metersFromNm(1.5), severity != "ALERT" )
then
    modify($c){ setSeverity("ALERT"); }
end

rule "R059_WarnIfBelowPrototypeRadarMinima"
when
    // Prototype use: FAA terminal 3 NM minima as a threshold idea. :contentReference[oaicite:56]{index=56}
    $c : ConflictCandidate( distM < metersFromNm(3.0), severity == "INFO" )
then
    modify($c){ setSeverity("WARN"); }
end

rule "R060_AlertIfBelowPrototypeRadarMinima"
when
    $c : ConflictCandidate( distM < metersFromNm(3.0), severity == "WARN" )
then
    modify($c){ setSeverity("ALERT"); }
end

rule "R061_WarnIfTTCWithinWarningTime"
when
    $p : Params()
    $c : :contentReference[oaicite:57]{index=57}p.warnTtcSec, severity == "INFO" )
then
    modify($c){ setSeverity("WARN"); }
end

rule "R062_AlertIfTTCWithinAlertTime"
when
    $p : Params()
    $c : ConflictCandidate( ttcSec < $p.alertTtcSec, severity != "ALERT" )
then
    modify($c){ setSeverity("ALERT"); }
end

rule "R063_SuppressIfNotClosingAndFar"
when
    $p : Params()
    $c : ConflictCandidate( closing == false, distM > metersFromNm($p.nearDistNm) )
then
    retract($c);
end

rule "R064_SuppressIfAnyOnGround"
when
    $c : ConflictCandidate( $a:a, $b:b )
    ( StateVector( icao24 == $a, onGround == true ) or StateVector( icao24 == $b, onGround == true ) )
then
    retract($c);
end

rule "R065_ConflictCandidateAudit_WARN"
when
    $c : ConflictCandidate( severity == "WARN" )
then
    insert(new AuditEvent("CONFLICT_WARN", $c.getA()+"|"+$c.getB(), NOW_EPOCH_SEC, "distNm="+nm($c.getDistM())+" ttc="+$c.getTtcSec()));
end

rule "R066_ConflictCandidateAudit_ALERT"
when
    $c : ConflictCandidate( severity == "ALERT" )
then
    insert(new AuditEvent("CONFLICT_ALERT", $c.getA()+"|"+$c.getB(), NOW_EPOCH_SEC, "distNm="+nm($c.getDistM())+" ttc="+$c.getTtcSec()));
end

rule "R067_DedupeConflictCandidates"
when
    $c1 : ConflictCandidate( $k:(a+"|"+b) )
    $c2 : ConflictCandidate( this != $c1, (a+"|"+b) == $k )
then
    // keep the most severe
    if($c2.getSeverity().equals("ALERT")) retract($c1);
    else retract($c2);
end

rule "R068_ClearOldConflictCandidates"
when
    $c : ConflictCandidate()
then
    // host may clear per cycle; we retract to avoid accumulation
    retract($c);
end

/* R069–R080 reserved for additional geometry/airspace-specific conflict logic:
   - climb/descent convergence
   - overtaking patterns
   - holding patterns near fixes
   - multi-aircraft cluster escalation
   (All still grounded in STCA "conflict" and warning time notions.) :contentReference[oaicite:58]{index=58} :contentReference[oaicite:59]{index=59}
*/



/* ============================================================
   R069–R072: Build conflict candidates using CPA (prediction)
   Semantics: "conflict" is a predicted violation of separation minima,
   warning time depends on geometry. :contentReference[oaicite:4]{index=4} :contentReference[oaicite:5]{index=5}
   ============================================================ */

rule "R069_CreateConflictFromCpaMetrics"
when
    $p : Params()
    $m : CpaMetrics( $a:a, $b:b, closing == true, tCpaSec > 0 )
then
    // turn CPA result into a conflict candidate seed (INFO; later rules may upgrade)
    insert(new ConflictCandidate($a, $b, $m.getDCpaM(), $m.getVertAtCpaM(), true, $m.getTCpaSec(), "INFO"));
end

rule "R070_SuppressIfNotClosingOrPastCPA"
when
    $c : ConflictCandidate( $a:a, $b:b )
    CpaMetrics( a == $a, b == $b, (closing == false || tCpaSec <= 0) )
then
    retract($c);
end

rule "R071_UpgradeToWARN_UsingCPA"
when
    $p : Params()
    $c : ConflictCandidate( severity == "INFO", $a:a, $b:b )
    CpaMetrics( a == $a, b == $b,
                ( dCpaM <= metersFromNm($p.getWarnDistNm()) || tCpaSec <= $p.getWarnTtcSec() ) )
then
    modify($c){ setSeverity("WARN"); }
end

rule "R072_UpgradeToALERT_UsingCPA"
when
    $p : Params()
    $c : ConflictCandidate( severity != "ALERT", $a:a, $b:b )
    CpaMetrics( a == $a, b == $b,
                ( dCpaM <= metersFromNm($p.getAlertDistNm()) || tCpaSec <= $p.getAlertTtcSec() ) )
then
    modify($c){ setSeverity("ALERT"); }
end


/* ============================================================
   R073–R076: Nuisance reduction via persistence + hysteresis
   Semantics: keep nuisance/false alerts to an effective minimum,
   and continue alert(s) while conditions exist. :contentReference[oaicite:6]{index=6}
   ============================================================ */

rule "R073_InitPairRiskState"
when
    $c : ConflictCandidate( $k:(a+"|"+b) )
    not PairRiskState( key == $k )
then
    insert(new PairRiskState($k, NOW_EPOCH_SEC, 0, 0, 0));
end

rule "R074_UpdateStreaks"
when
    $p : Params()
    $c : ConflictCandidate( $k:(a+"|"+b), $sev:severity )
    $s : PairRiskState( key == $k )
then
    int warn = $s.getWarnStreak();
    int alert = $s.getAlertStreak();
    int safe = $s.getSafeStreak();

    // simple persistence logic: require 2 consecutive frames before acting
    if("ALERT".equals($sev)){
        alert++; warn = 0; safe = 0;
    } else if("WARN".equals($sev)){
        warn++; alert = 0; safe = 0;
    } else {
        safe++; warn = 0; alert = 0;
    }

    modify($s){
        setLastAtSec(NOW_EPOCH_SEC);
        setWarnStreak(warn);
        setAlertStreak(alert);
        setSafeStreak(safe);
    }
end

rule "R075_RaiseAlertsOnlyAfterPersistence"
when
    // Nuisance reduction: only raise after persistence (2 frames).
    // This supports keeping nuisance alerts minimal. :contentReference[oaicite:7]{index=7}
    $c : ConflictCandidate( $a:a, $b:b, $k:(a+"|"+b) )
    $s : PairRiskState( key == $k, alertStreak >= 2 )
    not Alert( a == $a, b == $b, type == "SAFETY_ALERT" )
then
    insert(new Alert($a,$b,"SAFETY_ALERT","ALERT",NOW_EPOCH_SEC,"CPA-based persistent ALERT"));
end

rule "R076_Hysteresis_ClearOnlyAfterSafePersistence"
when
    // STCA-14: continue alerts as long as conditions exist (don’t flicker). :contentReference[oaicite:8]{index=8}
    $al : Alert( $a:a, $b:b, type == "SAFETY_ALERT" )
    $s  : PairRiskState( key == ($a+"|"+$b), safeStreak >= 3 )
then
    retract($al);
end


/* ============================================================
   R077–R078: Inhibition and "must be known"
   Semantics: inhibit for volumes/flights; inhibitions must be made known. :contentReference[oaicite:9]{index=9}
   ============================================================ */

rule "R077_InhibitSafetyAlertsByPair"
when
    $al : Alert( $a:a, $b:b, type == "SAFETY_ALERT" )
    AlertInhibit( kind == "FLIGHTPAIR", key == ($a+"|"+$b), enabled == true )
then
    retract($al);
    insert(new AuditEvent("INHIBIT_EFFECT", $a+"|"+$b, NOW_EPOCH_SEC, "suppressed SAFETY_ALERT by pair inhibition"));
end

rule "R078_InhibitMustBeKnown_Audit"
when
    $i : AlertInhibit( enabled == true )
then
    // STCA-16 requires inhibitions are made known to controllers. :contentReference[oaicite:10]{index=10}
    insert(new AuditEvent("INHIBIT_SET", $i.getKind()+":"+ $i.getKey(), NOW_EPOCH_SEC, "inhibit enabled/visible"));
end


/* ============================================================
   R079–R080: Join-heavy escalation + logging hooks
   Semantics: safety alert priority (FAA) + operational awareness. :contentReference[oaicite:11]{index=11}
   ============================================================ */

rule "R079_MultiConflictHotspotEscalation"
when
    // If one aircraft is in >=3 ALERT candidates at once, raise a hotspot audit.
    // (Join-heavy; useful for perf experiments.)
    $c1 : ConflictCandidate( severity == "ALERT", $x:a )
    $c2 : ConflictCandidate( severity == "ALERT", a == $x, this != $c1 )
    $c3 : ConflictCandidate( severity == "ALERT", a == $x, this != $c1, this != $c2 )
then
    insert(new AuditEvent("HOTSPOT", $x, NOW_EPOCH_SEC, "aircraft involved in multiple ALERT conflicts"));
end

rule "R080_RecordCPAForAnalysis"
when
    // STCA performance should be analysed; retain electronic records of alerts. :contentReference[oaicite:12]{index=12}
    $m : CpaMetrics()
then
    insert(new AuditEvent("CPA_METRICS", $m.getA()+"|"+$m.getB(), NOW_EPOCH_SEC,
        "tCPA="+$m.getTCpaSec()+" dCPA_m="+$m.getDCpaM()+" vertAtCPA_m="+$m.getVertAtCpaM()));
end



/* ============================================================
   ALERTING POLICY + INHIBITION (R081–R095)
   - STCA alerts must attract attention and identify aircraft. :contentReference[oaicite:62]{index=62}
   - Continue alert as long as conditions exist. :contentReference[oaicite:63]{index=63}
   - Allow inhibition for airspace volumes / flights, and make it known. :contentReference[oaicite:64]{index=64}
   - FAA: safety alert priority + traffic advisories/safety alerts. :contentReference[oaicite:65]{index=65} :contentReference[oaicite:66]{index=66}
   - FAA: suppress/inhibit must be coordinated (used as policy :contentReference[oaicite:67]{index=67}:contentReference[oaicite:68]{index=68}
   ================================:contentReference[oaicite:69]{index=69}*/

rule "R081_RaiseTrafficAdvisoryOnWARN"
when
    $c : ConflictCandidate:contentReference[oaicite:70]{index=70}b:b )
    not Alert( a == $a, b == $b, type == "TRAFFIC_ADVISORY" )
t:contentReference[oaicite:71]{index=71}$:contentReference[oaicite:72]{index=72}OW_EPOCH_SEC,"WARN conflict candidate"));
end

rule "R082_RaiseSafetyAlertOnAL:contentReference[oaicite:73]{index=73}ndidate( severity == "ALERT", $a:a, $b:b )
    not Alert( a == $a, b == $b, type == "SAFETY_ALERT" )
then
    insert(new Alert($a,$b,"SAFETY_ALERT","ALERT",NOW_EPOCH_SEC,"ALERT conflict candidate"));
end

rule "R083_AlertPersistsWhileConditionExists"
when
    $p : Params()
    $a : Alert( $key:(a+"|"+b+"|"+type), createdAt <= (NOW_EPOCH_SEC - $p.persistSec) )
    not AlertAck( key == $key )
then
    // keep alert (no retract) - this rule documents persistence intent per STCA-14
end

rule "R084_AckSilencesAudibleEquivalent"
when
    $al : Alert( $key:(a+"|"+b+"|"+type) )
    AlertAck( key == $key )
then
    // in a real HMI: silence audio; we simply keep the alert but can downgrade
    modify($al){ setSeverity("ACK"); }
end

rule "R085_ClearAlertAfterAckAndNoNewConflicts"
when
    $al : Alert( $key:(a+"|"+b+"|"+type), severity == "ACK" )
    AlertAck( key == $key, $t:at )
    eval(NOW_EPOCH_SEC - $t > 30)
then
    retract($al);
end

rule "R086_InhibitAlertsByFlight"
when
    $al : Alert( $a:a, $b:b )
    ( AlertInhibit( kind == "FLIGHT", key == $a, enabled == true )
      or
      AlertInhibit( kind == "FLIGHT", key == $b, enabled == true ) )
then
    retract($al);
end

rule "R087_InhibitAlertsByPair"
when
    $al : Alert( $a:a, $b:b )
    AlertInhibit( kind == "FLIGHTPAIR", key == ($a+"|"+$b), enabled == true )
then
    retract($al);
end

rule "R088_InhibitionMustBeKnown_Audit"
when
    $i : AlertInhibit( enabled == true )
then
    insert(new AuditEvent("INHIBIT_SET", $i.getKind()+":"+ $i.getKey(), NOW_EPOCH_SEC, "inhibit enabled"));
end

rule "R089_StatusWhenNotAvailable"
when
    Status( stcaAvailable == false )
then
    insert(new AuditEvent("STATUS", "STCA_UNAVAILABLE", NOW_EPOCH_SEC, "Status info per STCA-17"));
end

rule "R090_SafetyAlertPriorityAudit"
when
    $al : Alert( type == "SAFETY_ALERT" )
then
    insert(new AuditEvent("PRIORITY", $al.getA()+"|"+$al.getB(), NOW_EPOCH_SEC, "safety alert priority concept"));
end

rule "R091_TrafficAdvisoryAudit"
when
    $al : Alert( type == "TRAFFIC_ADVISORY" )
then
    insert(new AuditEvent("ADVISORY", $al.getA()+"|"+$al.getB(), NOW_EPOCH_SEC, "traffic advisory issued"));
end

rule "R092_DoNotSpamNuisanceAlerts"
when
    // nuisance alerts should be kept to an effective minimum (STCA-11/12)
    $al : Alert( $a:a, $b:b, $t:createdAt )
    Alert( this != $al, a == $a, b == $b, (NOW_EPOCH_SEC - $t) < 10 )
then
    retract($al);
end

rule "R093_EscalateFromAdvisoryToSafetyAlert"
when
    $ta : Alert( $a:a, $b:b, type == "TRAFFIC_ADVISORY" )
    Alert( a == $a, b == $b, type == "SAFETY_ALERT" )
then
    retract($ta);
end

rule "R094_ClearOldAdvisories"
when
    $ta : Alert( type == "TRAFFIC_ADVISORY", $t:createdAt )
    eval(NOW_EPOCH_SEC - $t > 120)
then
    retract($ta);
end

rule "R095_ClearOldAcks"
when
    $ack : AlertAck( $t:at )
    eval(NOW_EPOCH_SEC - $t > 600)
then
    retract($ack);
end


