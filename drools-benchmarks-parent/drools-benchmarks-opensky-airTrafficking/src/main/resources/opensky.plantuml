  + toString(): String
  + setB(String): void
  + getA(): String
  + setA(String): void
  + setCellId(String): void
  + getB(): String
  + getCellId(): String
}
class PairRiskState {
  - lastAtSec: Double
  - safeStreak: int
  - key: String
  - alertStreak: int
  - warnStreak: int
  + getWarnStreak(): int
  + setWarnStreak(int): void
  + setSafeStreak(int): void
  + getAlertStreak(): int
  + toString(): String
  + setAlertStreak(int): void
  + setLastAtSec(Double): void
  + getSafeStreak(): int
  + getKey(): String
  + getLastAtSec(): Double
  + setKey(String): void
}
class Params {
  - stalePosSec: Long
  - alertDistNm: Double
  - persistSec: Double
  - nearDistNm: Double
  - gridDeg: Double
  - alertTtcSec: Double
  - staleAnySec: Long
  - warnDistNm: Double
  - vertMinFt: Double
  - warnTtcSec: Double
  + getVertMinFt(): Double
  + setPersistSec(Double): void
  + getGridDeg(): Double
  + setNearDistNm(Double): void
  + setAlertTtcSec(Double): void
  + setAlertDistNm(Double): void
  + getWarnTtcSec(): Double
  + setWarnTtcSec(Double): void
  + getNearDistNm(): Double
  + toString(): String
  + getAlertDistNm(): Double
  + setVertMinFt(Double): void
  + setGridDeg(Double): void
  + setStalePosSec(Long): void
  + getStaleAnySec(): Long
  + setWarnDistNm(Double): void
  + getStalePosSec(): Long
  + getAlertTtcSec(): Double
  + getWarnDistNm(): Double
  + setStaleAnySec(Long): void
  + getPersistSec(): Double
}
class RuleMathUtil {
  - EARTH_RADIUS_M: double
  - METERS_PER_NM: double
  + nm(double): double
  + metersFromNm(double): double
  + haversineMeters(double, double, double, double): double
  + timeToCpaSec(double, double, double, double): double
}
class Status {
  - at: Double
  - stcaAvailable: Boolean
  + getStcaAvailable(): Boolean
  + setStcaAvailable(Boolean): void
  + toString(): String
  + getAt(): Double
  + setAt(Double): void
}
class TrackQuality {
  - missingPos: Boolean
  - badAlt: Boolean
  - reason: String
  - staleAny: Boolean
  - icao24: String
  - stalePos: Boolean
  - badVel: Boolean
  + setMissingPos(Boolean): void
  + getIcao24(): String
  + getBadAlt(): Boolean
  + getStaleAny(): Boolean
  + setBadAlt(Boolean): void
  + getBadVel(): Boolean
  + setReason(String): void
  + setStalePos(Boolean): void
  + toString(): String
  + getMissingPos(): Boolean
  + setIcao24(String): void
  + setBadVel(Boolean): void
  + setStaleAny(Boolean): void
  + getStalePos(): Boolean
  + getReason(): String
}

OpenSkyReplayDroolsBenchmark  -[#595959,dashed]->  OpenSkyJsonlLoader           : "«create»"
OpenSkyReplayDroolsBenchmark "1" *-[#595959,plain]-> "engine\n1" OpenSkyReplayEngine          
OpenSkyReplayDroolsBenchmark  -[#595959,dashed]->  OpenSkyReplayEngine          : "«create»"
@enduml
