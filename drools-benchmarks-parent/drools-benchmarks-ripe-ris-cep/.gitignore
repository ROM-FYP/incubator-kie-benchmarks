# ---------------------------------------------------------------
# drools-benchmarks-ripe-ris-cep — module-level .gitignore
# ---------------------------------------------------------------

# Maven build output
target/
dependency-reduced-pom.xml

# Package artifacts
*.jar
*.war
*.ear
*.class

# ---------------------------------------------------------------
# IDE files
# ---------------------------------------------------------------
.idea/
*.iml
*.ipr
*.iws
.vscode/
.settings/
.classpath
.project
/nbproject
.mtj.tmp/

# ---------------------------------------------------------------
# Environment and local configuration
# .env holds sensitive paths/URLs — never commit
# ---------------------------------------------------------------
.env

# ---------------------------------------------------------------
# RIS / BGP event data files
# These can be hundreds of MB to tens of GB.
# Keep the data/ directory itself but ignore its contents.
# ---------------------------------------------------------------
/data/*.jsonl
/data/*.json
/data/*.gz
/data/*.zst

# Causal trace output (can reach 80 GB+)
riperis_causal_trace.jsonl
riperis_causal_trace_*.jsonl

# Recorded trace output directory
/traces/

# ---------------------------------------------------------------
# JMH / benchmark outputs
# ---------------------------------------------------------------
jmh-result.json
jmh-result-*.json
*.jfr
benchmark_results/
*.jmh.log

# ---------------------------------------------------------------
# Research result files (keep templates, ignore generated output)
# ---------------------------------------------------------------
docs/results/*.csv
docs/results/*.html
docs/results/*.json
docs/results/*.jfr
docs/results/*.md
# Allow the directory and any committed README/template files
!docs/results/.gitkeep
!docs/results/README.md

# ---------------------------------------------------------------
# JVM crash and replay logs
# ---------------------------------------------------------------
hs_err_pid*.log
replay_pid*.log
hs_err_pid*
replay_pid*

# ---------------------------------------------------------------
# Gephi / network graph exports
# ---------------------------------------------------------------
*.net
*.net.ftree
*.gexf
*.graphml

# ---------------------------------------------------------------
# Characterization collector outputs
# ---------------------------------------------------------------
characterization_*.json
characterization_*.csv
characterization_*.txt

# ---------------------------------------------------------------
# OS artefacts
# ---------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------
# Temporary / editor swap files
# ---------------------------------------------------------------
*.tmp
*.bak
*~
*.swp
*.swo
