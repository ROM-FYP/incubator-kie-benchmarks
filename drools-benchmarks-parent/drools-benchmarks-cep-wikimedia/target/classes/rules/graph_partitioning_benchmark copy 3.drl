package org.drools.benchmark.wiki;

import org.kie.benchmark.cep.wikimedia.model.WikiEvent;
import java.util.List;
import java.util.ArrayList;

// ============================================================================
// FACT DECLARATIONS WITH STREAM SUPPORT
// ============================================================================

declare WikiEvent
    @role(event)
    @expires(10s)
end

declare UserContext
    // Not an event, stable fact
    user : String @key
    reputation : int
    editCount : int
    accountAge : int
    warnings : int
end

declare VerifiedEdit
    @role(event)
    @expires(10s)
    user : String
    title : String
    sizeDelta : int
    timestamp : long
end

declare ContentAnalysis
    @role(event)
    @expires(10s)
    title : String
    content : String
    sentiment : double
    complexity : int
    flags : java.util.List
end

declare BotAction
    @role(event)
    @expires(10s)
    user : String
    type : String
    velocity : int
end

declare BotVelocity
    @role(event)
    @expires(10s)
    user : String
    actionsPerMinute : double
    burstDetected : boolean
end

declare GlobalPattern
    @role(event)
    @expires(10s)
    pattern : String
    sourceWiki : String
    targetWiki : String
    correlation : double
end

declare Alert
    @role(event)
    @expires(60s)
    alertType : String
    severity : int
    user : String
    title : String
    details : String
    timestamp : long
end

declare DeepCryptoFlag
    @role(event)
    @expires(10s)
    title : String
    user : String
    sizeDelta : int
    riskScore : double
end

declare CryptoScamAlert
    @role(event)
    @expires(10s)
    title : String
    user : String
    evidence : String
    severity : int
end

// ============================================================================
// CLUSTER 1: THE "EDIT PIPELINE"
// ============================================================================

rule "C1_R01_Enrich_User_Context"
when
    $e : WikiEvent( sizeDelta != 0, $user : user )
    not UserContext( user == $user )
then
    int reputation = Math.abs($user.hashCode() % 100);
    int editCount = Math.abs($user.hashCode() % 5000);
    int accountAge = Math.abs($user.hashCode() % 3650);
    int warnings = Math.abs($user.hashCode() % 10);
    
    insert(new UserContext($user, reputation, editCount, accountAge, warnings));
end

rule "C1_R02_Create_Verified_Edit"
when
    $e : WikiEvent( sizeDelta != 0, $user : user, $title : title, $diff : sizeDelta )
    $uc : UserContext( user == $user, reputation >= 0 )
then
    insert(new VerifiedEdit($user, $title, $diff, System.currentTimeMillis()));
end

// ----------------------------------------------------------------------------
// Granular Edit Size Rules (10 Buckets)
// ----------------------------------------------------------------------------

rule "Size_Tier_01_Micro"
when
    $ve : VerifiedEdit( sizeDelta < 10 )
then end

rule "Size_Tier_02_Tiny"
when
    $ve : VerifiedEdit( sizeDelta >= 10, sizeDelta < 50 )
then end

rule "Size_Tier_03_Small"
when
    $ve : VerifiedEdit( sizeDelta >= 50, sizeDelta < 100 )
then end

rule "Size_Tier_04_Minor"
when
    $ve : VerifiedEdit( sizeDelta >= 100, sizeDelta < 250 )
then end

rule "Size_Tier_05_Standard"
when
    $ve : VerifiedEdit( sizeDelta >= 250, sizeDelta < 500 )
then end

rule "Size_Tier_06_Medium"
when
    $ve : VerifiedEdit( sizeDelta >= 500, sizeDelta < 1000 )
then end

rule "Size_Tier_07_Large"
when
    $ve : VerifiedEdit( sizeDelta >= 1000, sizeDelta < 2500 )
then end

rule "Size_Tier_08_Major"
when
    $ve : VerifiedEdit( sizeDelta >= 2500, sizeDelta < 5000 )
then end

rule "Size_Tier_09_Massive"
when
    $ve : VerifiedEdit( sizeDelta >= 5000, sizeDelta < 10000 )
then end

rule "Size_Tier_10_Epic"
when
    $ve : VerifiedEdit( sizeDelta >= 10000 )
then end


// ----------------------------------------------------------------------------
// Granular Reputation Rules (10 Buckets)
// ----------------------------------------------------------------------------

rule "Reputation_Tier_00"
when
    $ve : VerifiedEdit( $user : user )
    $uc : UserContext( user == $user, reputation < 10 )
then end

rule "Reputation_Tier_01"
when
    $ve : VerifiedEdit( $user : user )
    $uc : UserContext( user == $user, reputation >= 10, reputation < 20 )
then end

rule "Reputation_Tier_02"
when
    $ve : VerifiedEdit( $user : user )
    $uc : UserContext( user == $user, reputation >= 20, reputation < 30 )
then end

rule "Reputation_Tier_03"
when
    $ve : VerifiedEdit( $user : user )
    $uc : UserContext( user == $user, reputation >= 30, reputation < 40 )
then end

rule "Reputation_Tier_04"
when
    $ve : VerifiedEdit( $user : user )
    $uc : UserContext( user == $user, reputation >= 40, reputation < 50 )
then end

rule "Reputation_Tier_05"
when
    $ve : VerifiedEdit( $user : user )
    $uc : UserContext( user == $user, reputation >= 50, reputation < 60 )
then end

rule "Reputation_Tier_06"
when
    $ve : VerifiedEdit( $user : user )
    $uc : UserContext( user == $user, reputation >= 60, reputation < 70 )
then end

rule "Reputation_Tier_07"
when
    $ve : VerifiedEdit( $user : user )
    $uc : UserContext( user == $user, reputation >= 70, reputation < 80 )
then end

rule "Reputation_Tier_08"
when
    $ve : VerifiedEdit( $user : user )
    $uc : UserContext( user == $user, reputation >= 80, reputation < 90 )
then end

rule "Reputation_Tier_09"
when
    $ve : VerifiedEdit( $user : user )
    $uc : UserContext( user == $user, reputation >= 90 )
then end

// ============================================================================
// CLUSTER 2: THE "DEEP INSPECTION"
// ============================================================================

rule "C2_R01_Deep_Crypto_Scan"
when
    $ve : VerifiedEdit( sizeDelta > 1000, 
                        // Simplified checks for performance
                        title.toLowerCase().contains("crypto") || 
                        title.toLowerCase().contains("bitcoin"),
                        $user : user, $title : title, $diff : sizeDelta )
    $uc : UserContext( user == $user, reputation >= 0 )
then
    double riskScore = ($diff * 1.0) / ($uc.getReputation() + 1.0);
    insertLogical(new DeepCryptoFlag($title, $user, $diff, riskScore));
end

rule "C2_R02_Crypto_Pattern_Analysis"
when
    $dcf : DeepCryptoFlag( riskScore > 10.0, $user : user, $title : title )
    $uc : UserContext( user == $user, warnings > 2 )
then
    insertLogical(new CryptoScamAlert($title, $user, "High risk crypto edit by warned user", 3));
end

rule "C2_R04_Alert_Crypto_Scam"
when
    $csa : CryptoScamAlert( severity >= 3, $title : title, $user : user, $evidence : evidence )
then
    insert(new Alert("CRYPTO_SCAM", $csa.getSeverity(), $user, $title, $evidence, System.currentTimeMillis()));
end

// ============================================================================
// CLUSTER 3: THE "BOT SWARM" (WINDOWED ACCUMULATES)
// ============================================================================

rule "C3_R01_Detect_Bot_Action"
when
    $e : WikiEvent( bot == true, $user : user )
then
    insert(new BotAction($user, "bot_edit", 1));
end

rule "C3_R02_Calculate_Bot_Velocity"
when
    $ba1 : BotAction( $user : user )
    $count : Number( intValue > 10 ) from accumulate(
        $b : BotAction( user == $user ) over window:time(10s),
        count($b)
    )
then
    double velocity = $count.doubleValue();
    insert(new BotVelocity($user, velocity, velocity > 50));
end

// Granular Bot Burst Detection
rule "Bot_Burst_Tier_1_Low"
when
    $bv : BotVelocity( actionsPerMinute >= 10, actionsPerMinute < 30, $user : user )
then
    // Log
end

rule "Bot_Burst_Tier_2_Medium"
when
    $bv : BotVelocity( actionsPerMinute >= 30, actionsPerMinute < 60, $user : user )
then
    // Log
end

rule "Bot_Burst_Tier_3_High"
when
    $bv : BotVelocity( actionsPerMinute >= 60, actionsPerMinute < 100, $user : user )
then
    insert(new Alert("BOT_HIGH", 2, $user, "Bot Activity", "High velocity", System.currentTimeMillis()));
end

rule "Bot_Burst_Tier_4_Extreme"
when
    $bv : BotVelocity( actionsPerMinute >= 100, $user : user )
then
    insert(new Alert("BOT_EXTREME", 4, $user, "Bot Activity", "Extreme velocity", System.currentTimeMillis()));
end

// ============================================================================
// CLUSTER 4: TEMPORAL JOINS (VARIATIONS)
// ============================================================================

// Immediate correlation (0-1s)
rule "Cross_Wiki_Immediate"
when
    $e1 : WikiEvent( sizeDelta > 0, $title1 : title )
    $e2 : WikiEvent( this != $e1, this after[0, 1s] $e1, 
                     sizeDelta > 0, $title2 : title, title != $title1 )
    eval( $title1.startsWith("Talk:") && $title2.startsWith("Talk:") )
then
    insert(new GlobalPattern("CROSS_WIKI_IMMEDIATE", $title1, $title2, 0.9));
end

// Fast correlation (1-5s)
rule "Cross_Wiki_Exploits"
when
    $e1 : WikiEvent( sizeDelta > 100, $title1 : title )
    $e2 : WikiEvent( this != $e1, this after[1s, 5s] $e1, 
                     sizeDelta > 100, $title2 : title, title != $title1 )
    eval( $title1.length() == $title2.length() )
then
    insert(new GlobalPattern("CROSS_WIKI_FAST", $title1, $title2, 0.7));
end

// Slow correlation (5-10s)
rule "Cross_Wiki_Coordinated"
when
    $e1 : WikiEvent( sizeDelta > 500, $title1 : title )
    $e2 : WikiEvent( this != $e1, this after[5s, 10s] $e1, 
                     sizeDelta > 500, $title2 : title, title != $title1 )
then
    insert(new GlobalPattern("CROSS_WIKI_SLOW", $title1, $title2, 0.5));
end

// ============================================================================
// ALERT AGGREGATION
// ============================================================================

rule "Alert_R01_High_Severity_Aggregation"
when
    $count : Number( intValue >= 3 ) from accumulate(
        $a : Alert( severity >= 4 ) over window:time(30s),
        count($a)
    )
then
end

rule "Alert_R02_User_Alert_Count"
when
    $user : String()
    exists( Alert( user == $user ) )
    $count : Number( intValue >= 5 ) from accumulate(
        $a : Alert( user == $user ) over window:time(30s),
        count($a)
    )
then
    insert(new Alert("ALERT_STORM", 5, $user, "Multiple Alerts", "User triggered many alerts", System.currentTimeMillis()));
end
