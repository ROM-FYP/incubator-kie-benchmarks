package org.drools.benchmark.wiki;

import org.kie.benchmark.cep.wikimedia.model.WikiEvent;

// ============================================================================
// BALANCED CLUSTER RULESET V5 - LOCK-STEP EXECUTION
// ============================================================================
// 
// Problem: When multiple events arrive together, all R1 rules fire, then R2, etc.
// This creates cross-cluster interleaving in the trace.
//
// Solution: Use lock-on-active to prevent re-entry, and structure chains so
// each event triggers ONLY its cluster. Also use activation-groups to ensure
// only one trigger fires per event.
//
// Key: Route events by title hash to EXACTLY one cluster per event.
// ============================================================================

declare WikiEvent @role(event) @expires(60s) end

// Unique fact types per cluster for complete isolation
declare AlphaFact1 @role(event) @expires(3s) id : String; end
declare AlphaFact2 @role(event) @expires(3s) id : String; end
declare AlphaFact3 @role(event) @expires(3s) id : String; end
declare AlphaFact4 @role(event) @expires(3s) id : String; end
declare AlphaFact5 @role(event) @expires(3s) id : String; end

declare BetaFact1 @role(event) @expires(3s) id : String; end
declare BetaFact2 @role(event) @expires(3s) id : String; end
declare BetaFact3 @role(event) @expires(3s) id : String; end
declare BetaFact4 @role(event) @expires(3s) id : String; end
declare BetaFact5 @role(event) @expires(3s) id : String; end

declare GammaFact1 @role(event) @expires(3s) id : String; end
declare GammaFact2 @role(event) @expires(3s) id : String; end
declare GammaFact3 @role(event) @expires(3s) id : String; end
declare GammaFact4 @role(event) @expires(3s) id : String; end
declare GammaFact5 @role(event) @expires(3s) id : String; end

declare DeltaFact1 @role(event) @expires(3s) id : String; end
declare DeltaFact2 @role(event) @expires(3s) id : String; end
declare DeltaFact3 @role(event) @expires(3s) id : String; end
declare DeltaFact4 @role(event) @expires(3s) id : String; end
declare DeltaFact5 @role(event) @expires(3s) id : String; end

declare EpsFact1 @role(event) @expires(3s) id : String; end
declare EpsFact2 @role(event) @expires(3s) id : String; end
declare EpsFact3 @role(event) @expires(3s) id : String; end
declare EpsFact4 @role(event) @expires(3s) id : String; end
declare EpsFact5 @role(event) @expires(3s) id : String; end

// ============================================================================
// CLUSTER ALPHA (hash % 5 == 0) - 6 rule chain
// Each stage has unique salience offset to prevent cross-cluster interleaving
// ============================================================================
rule "Alpha_Stage1" salience 500 when $e : WikiEvent( Math.abs(title.hashCode()) % 5 == 0, $t : title ) then insert(new AlphaFact1($t)); end
rule "Alpha_Stage2" salience 495 when $a : AlphaFact1( $id : id ) then insert(new AlphaFact2($id)); retract($a); end
rule "Alpha_Stage3" salience 490 when $a : AlphaFact2( $id : id ) then insert(new AlphaFact3($id)); retract($a); end
rule "Alpha_Stage4" salience 485 when $a : AlphaFact3( $id : id ) then insert(new AlphaFact4($id)); retract($a); end
rule "Alpha_Stage5" salience 480 when $a : AlphaFact4( $id : id ) then insert(new AlphaFact5($id)); retract($a); end
rule "Alpha_Stage6" salience 475 when $a : AlphaFact5() then retract($a); end

// ============================================================================
// CLUSTER BETA (hash % 5 == 1) - 6 rule chain
// ============================================================================
rule "Beta_Stage1" salience 400 when $e : WikiEvent( Math.abs(title.hashCode()) % 5 == 1, $t : title ) then insert(new BetaFact1($t)); end
rule "Beta_Stage2" salience 395 when $b : BetaFact1( $id : id ) then insert(new BetaFact2($id)); retract($b); end
rule "Beta_Stage3" salience 390 when $b : BetaFact2( $id : id ) then insert(new BetaFact3($id)); retract($b); end
rule "Beta_Stage4" salience 385 when $b : BetaFact3( $id : id ) then insert(new BetaFact4($id)); retract($b); end
rule "Beta_Stage5" salience 380 when $b : BetaFact4( $id : id ) then insert(new BetaFact5($id)); retract($b); end
rule "Beta_Stage6" salience 375 when $b : BetaFact5() then retract($b); end

// ============================================================================
// CLUSTER GAMMA (hash % 5 == 2) - 6 rule chain
// ============================================================================
rule "Gamma_Stage1" salience 300 when $e : WikiEvent( Math.abs(title.hashCode()) % 5 == 2, $t : title ) then insert(new GammaFact1($t)); end
rule "Gamma_Stage2" salience 295 when $g : GammaFact1( $id : id ) then insert(new GammaFact2($id)); retract($g); end
rule "Gamma_Stage3" salience 290 when $g : GammaFact2( $id : id ) then insert(new GammaFact3($id)); retract($g); end
rule "Gamma_Stage4" salience 285 when $g : GammaFact3( $id : id ) then insert(new GammaFact4($id)); retract($g); end
rule "Gamma_Stage5" salience 280 when $g : GammaFact4( $id : id ) then insert(new GammaFact5($id)); retract($g); end
rule "Gamma_Stage6" salience 275 when $g : GammaFact5() then retract($g); end

// ============================================================================
// CLUSTER DELTA (hash % 5 == 3) - 6 rule chain
// ============================================================================
rule "Delta_Stage1" salience 200 when $e : WikiEvent( Math.abs(title.hashCode()) % 5 == 3, $t : title ) then insert(new DeltaFact1($t)); end
rule "Delta_Stage2" salience 195 when $d : DeltaFact1( $id : id ) then insert(new DeltaFact2($id)); retract($d); end
rule "Delta_Stage3" salience 190 when $d : DeltaFact2( $id : id ) then insert(new DeltaFact3($id)); retract($d); end
rule "Delta_Stage4" salience 185 when $d : DeltaFact3( $id : id ) then insert(new DeltaFact4($id)); retract($d); end
rule "Delta_Stage5" salience 180 when $d : DeltaFact4( $id : id ) then insert(new DeltaFact5($id)); retract($d); end
rule "Delta_Stage6" salience 175 when $d : DeltaFact5() then retract($d); end

// ============================================================================
// CLUSTER EPSILON (hash % 5 == 4) - 6 rule chain
// ============================================================================
rule "Epsilon_Stage1" salience 100 when $e : WikiEvent( Math.abs(title.hashCode()) % 5 == 4, $t : title ) then insert(new EpsFact1($t)); end
rule "Epsilon_Stage2" salience 95 when $eps : EpsFact1( $id : id ) then insert(new EpsFact2($id)); retract($eps); end
rule "Epsilon_Stage3" salience 90 when $eps : EpsFact2( $id : id ) then insert(new EpsFact3($id)); retract($eps); end
rule "Epsilon_Stage4" salience 85 when $eps : EpsFact3( $id : id ) then insert(new EpsFact4($id)); retract($eps); end
rule "Epsilon_Stage5" salience 80 when $eps : EpsFact4( $id : id ) then insert(new EpsFact5($id)); retract($eps); end
rule "Epsilon_Stage6" salience 75 when $eps : EpsFact5() then retract($eps); end
