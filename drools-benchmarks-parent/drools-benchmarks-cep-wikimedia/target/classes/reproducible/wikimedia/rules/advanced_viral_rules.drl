package org.drools.benchmark.wiki;

import java.util.Set;
import org.kie.benchmark.cep.reproducible.wikimedia.model.*;




rule "L1_Semantic_fix"
when
    $e : WikiEvent(
        bot == false,
        comment.toLowerCase().contains("fix"),
        sizeDelta > 50
    )
then
    insertLogical(new EditClassification(
        $e.getTitle(),
        "fix",
        10
    ));
end

