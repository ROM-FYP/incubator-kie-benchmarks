rule "L2_PageEditor"
when
    WikiEvent( $p : title, $u : user )
then
    insertLogical(new PageEditor($p, $u));
end

rule "L2_User_Diversity_Insert"
when
    $pe : PageEditor( $p : pageTitle )
    not UserDiversity( pageTitle == $p )
    $users : Set() from accumulate(
        PageEditor( pageTitle == $p, $u : user ),
        collectSet($u)
    )
then
    insert(new UserDiversity($p, $users.size()));
end

rule "L2_User_Diversity_Update"
when
    $ud : UserDiversity( $p : pageTitle )
    $users : Set() from accumulate(
        PageEditor( pageTitle == $p, $u : user ),
        collectSet($u)
    )
then
    modify($ud) { setEditors($users.size()) };
end

rule "L3_Edit_Velocity_Insert"
when
    $e : WikiEvent( $p : title )
    not EditVelocity( pageTitle == $p )
    $count : Number() from accumulate(
        WikiEvent( title == $p ) over window:time(30s),
        count(1)
    )
then
    insert(new EditVelocity($p, $count.doubleValue() / 30.0));
end

rule "L3_Edit_Velocity_Update"
when
    $e  : WikiEvent( $p : title )
    $ev : EditVelocity( pageTitle == $p )
    $count : Number() from accumulate(
        WikiEvent( title == $p ) over window:time(30s),
        count(1)
    )
then
    modify($ev) { setRate($count.doubleValue() / 60.0) };
end

rule "L4_Viral_Score_0"
when
    $c : EditClassification( type == "fix", $p : pageTitle )
    $u : UserDiversity( pageTitle == $p, editors >= 4 )
    $v : EditVelocity( pageTitle == $p, rate > 0.2 )
then
    double score =
        ($c.getWeight() * 2) +
        ($u.getEditors() * 5) +
        ($v.getRate() * 20);

    if (score >= 60) {
        insertLogical(new ViralTopicAlert(
            $p,
            "fix",
            score
        ));
    }
end

