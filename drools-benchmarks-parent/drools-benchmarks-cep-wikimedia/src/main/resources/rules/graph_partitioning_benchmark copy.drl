package org.drools.benchmark.wiki;

import org.kie.benchmark.cep.wikimedia.model.WikiEvent;

// ============================================================================
// FACT DECLARATIONS
// ============================================================================

declare UserContext
    user : String
    reputation : int
    editCount : int
    accountAge : int
    warnings : int
end

declare VerifiedEdit
    user : String
    title : String
    sizeDelta : int
    timestamp : long
end

declare ContentAnalysis
    title : String
    content : String
    sentiment : double
    complexity : int
    flags : java.util.List
end

declare BotAction
    user : String
    type : String
    velocity : int
end

declare BotVelocity
    user : String
    actionsPerMinute : double
    burstDetected : boolean
end

declare GlobalPattern
    pattern : String
    sourceWiki : String
    targetWiki : String
    correlation : double
end

declare Alert
    @role(event)
    alertType : String
    severity : int
    user : String
    title : String
    details : String
    timestamp : long
end

declare DeepCryptoFlag
    title : String
    user : String
    sizeDelta : int
    riskScore : double
end

declare CryptoScamAlert
    title : String
    user : String
    evidence : String
    severity : int
end

// ============================================================================
// CLUSTER 1: THE "EDIT PIPELINE" (HOT CORE - 90% of traffic)
// ============================================================================

// Entry Point: Create UserContext for all editors
rule "C1_R01_Enrich_User_Context"
when
    $e : WikiEvent( sizeDelta != 0, $user : user, $title : title, $diff : sizeDelta )
    not UserContext( user == $user )
then
    int reputation = Math.abs($user.hashCode() % 100);
    int editCount = Math.abs($user.hashCode() % 5000);
    int accountAge = Math.abs($user.hashCode() % 3650);
    int warnings = Math.abs($user.hashCode() % 10);
    
    insert(new UserContext($user, reputation, editCount, accountAge, warnings));
end

// Shared Enrichment: Create VerifiedEdit for high-rep users (HOT PATH)
rule "C1_R02_Create_Verified_Edit"
when
    $e : WikiEvent( sizeDelta != 0, $user : user, $title : title, $diff : sizeDelta )
    $uc : UserContext( user == $user, reputation >= 30 )
then
    insert(new VerifiedEdit($user, $title, $diff, System.currentTimeMillis()));
end

// HOT PATH: Log all verified edits (fires constantly)
rule "C1_R03_Log_Verified_Edit"
when
    $ve : VerifiedEdit( $user : user, $title : title )
then
    // This rule fires for 90% of edits
    // System.out.println("Verified edit by " + $user + " on " + $title);
end

// HOT PATH: Track verified edit velocity
rule "C1_R04_Track_Edit_Velocity"
when
    $ve : VerifiedEdit( $user : user, sizeDelta > 0 )
    $uc : UserContext( user == $user, editCount > 100 )
then
    // Track edit patterns
end

// HOT PATH: Analyze edit size
rule "C1_R05_Analyze_Edit_Size_Small"
when
    $ve : VerifiedEdit( sizeDelta < 100, $user : user )
then
    // Small edit processing
end

rule "C1_R06_Analyze_Edit_Size_Medium"
when
    $ve : VerifiedEdit( sizeDelta >= 100, sizeDelta < 500, $user : user )
then
    // Medium edit processing
end

rule "C1_R07_Analyze_Edit_Size_Large"
when
    $ve : VerifiedEdit( sizeDelta >= 500, sizeDelta < 1000, $user : user )
then
    // Large edit processing
end

// HOT PATH: Check user reputation tiers
rule "C1_R08_Reputation_Bronze"
when
    $uc : UserContext( reputation >= 50, reputation < 70 )
    $ve : VerifiedEdit( user == $uc.user )
then
    // Bronze tier processing
end

rule "C1_R09_Reputation_Silver"
when
    $uc : UserContext( reputation >= 70, reputation < 90 )
    $ve : VerifiedEdit( user == $uc.user )
then
    // Silver tier processing
end

rule "C1_R10_Reputation_Gold"
when
    $uc : UserContext( reputation >= 90 )
    $ve : VerifiedEdit( user == $uc.user )
then
    // Gold tier processing
end

// ============================================================================
// CLUSTER 2: THE "DEEP INSPECTION" (COLD PARASITE - shares upstream)
// ============================================================================

// COLD PATH: Shares Entry and Enrichment with Cluster 1, but rare trigger
rule "C2_R01_Deep_Crypto_Scan"
when
    $e : WikiEvent( sizeDelta != 0, $user : user, $title : title, $diff : sizeDelta )
    $uc : UserContext( user == $user, reputation >= 0 )
    $ve : VerifiedEdit( user == $user, title == $title, sizeDelta > 1000 )
    eval( $title.toLowerCase().contains("crypto") || 
          $title.toLowerCase().contains("bitcoin") ||
          $title.toLowerCase().contains("blockchain") )
then
    double riskScore = ($diff * 1.0) / ($uc.reputation + 1.0);
    insert(new DeepCryptoFlag($title, $user, $diff, riskScore));
end

// COLD PATH: Analyze crypto-related patterns
rule "C2_R02_Crypto_Pattern_Analysis"
when
    $dcf : DeepCryptoFlag( riskScore > 10.0, $user : user, $title : title )
    $uc : UserContext( user == $user, warnings > 2 )
then
    insert(new CryptoScamAlert($title, $user, "High risk crypto edit by warned user", 3));
end

// COLD PATH: Check for crypto scam keywords
rule "C2_R03_Detect_Scam_Keywords"
when
    $dcf : DeepCryptoFlag( $title : title )
    eval( $title.toLowerCase().contains("free") ||
          $title.toLowerCase().contains("guaranteed") ||
          $title.toLowerCase().contains("profit") )
then
    insert(new CryptoScamAlert($title, $dcf.user, "Scam keywords detected", 4));
end

// COLD PATH: Alert on crypto scam
rule "C2_R04_Alert_Crypto_Scam"
when
    $csa : CryptoScamAlert( severity >= 3, $title : title, $user : user, $evidence : evidence )
then
    insert(new Alert("CRYPTO_SCAM", $csa.severity, $user, $title, $evidence, System.currentTimeMillis()));
end

// COLD PATH: Deep content analysis for crypto pages
rule "C2_R05_Deep_Content_Analysis"
when
    $dcf : DeepCryptoFlag( riskScore > 15.0, $title : title )
then
    java.util.List flags = new java.util.ArrayList();
    flags.add("CRYPTO");
    flags.add("HIGH_RISK");
    insert(new ContentAnalysis($title, "", 0.5, 10, flags));
end

// COLD PATH: Cross-reference with user history
rule "C2_R06_Cross_Reference_History"
when
    $dcf : DeepCryptoFlag( $user : user )
    $uc : UserContext( user == $user, editCount < 50 )
then
    insert(new CryptoScamAlert($dcf.title, $user, "New user with suspicious crypto edit", 5));
end

// COLD PATH: Timestamp correlation
rule "C2_R07_Timestamp_Correlation"
when
    $dcf1 : DeepCryptoFlag( $user : user )
    $dcf2 : DeepCryptoFlag( user == $user, title != $dcf1.title, this != $dcf1 )
then
    insert(new Alert("CRYPTO_SPAM", 4, $user, "Multiple crypto pages", "Coordinated editing", System.currentTimeMillis()));
end

// ============================================================================
// CLUSTER 3: THE "BOT SWARM" (INDEPENDENT)
// ============================================================================

rule "C3_R01_Detect_Bot_Action"
when
    $e : WikiEvent( bot == true, $user : user )
then
    String actionType = "bot_edit";
    insert(new BotAction($user, actionType, 1));
end

rule "C3_R02_Calculate_Bot_Velocity"
when
    $ba1 : BotAction( $user : user )
    $count : Number( intValue > 10 ) from accumulate(
        BotAction( user == $user ),
        count(1)
    )
then
    double velocity = $count.doubleValue();
    insert(new BotVelocity($user, velocity, velocity > 50));
end

rule "C3_R03_Detect_Bot_Burst"
when
    $bv : BotVelocity( burstDetected == true, $user : user )
then
    insert(new Alert("BOT_BURST", 2, $user, "Bot Activity", "High velocity detected", System.currentTimeMillis()));
end

rule "C3_R04_Bot_Edit_Pattern"
when
    $ba : BotAction( $user : user )
    $bv : BotVelocity( user == $user, actionsPerMinute > 30 )
then
    insert(new Alert("BOT_FLOOD", 3, $user, "Bot Editing", "Possible flood", System.currentTimeMillis()));
end

rule "C3_R05_Bot_New_Pattern"
when
    $ba : BotAction( $user : user )
    $bv : BotVelocity( user == $user, actionsPerMinute > 20 )
then
    insert(new Alert("BOT_PAGE_CREATION", 2, $user, "Bot Pages", "Rapid page creation", System.currentTimeMillis()));
end

rule "C3_R06_Bot_Categorize_Pattern"
when
    $ba : BotAction( type == "categorize", $user : user )
    $count : Number( intValue > 50 ) from accumulate(
        BotAction( user == $user, type == "categorize" ),
        count(1)
    )
then
    insert(new Alert("BOT_CATEGORIZE", 1, $user, "Bot Categorization", "Mass categorization", System.currentTimeMillis()));
end

rule "C3_R07_Bot_Log_Pattern"
when
    $ba : BotAction( type == "log", $user : user )
    $bv : BotVelocity( user == $user )
then
    // Log bot activity
end

rule "C3_R08_Bot_Multi_Type"
when
    $ba1 : BotAction( $user : user, $type1 : type )
    $ba2 : BotAction( user == $user, type != $type1 )
then
    insert(new Alert("BOT_MULTI_ACTION", 2, $user, "Bot Behavior", "Multiple action types", System.currentTimeMillis()));
end

// ============================================================================
// CLUSTER 4: "CROSS-WIKI PATTERNS" (JOIN HEAVY)
// ============================================================================

rule "C4_R01_Detect_New_Page_EnWiki"
when
    $e : WikiEvent( sizeDelta > 0, $title : title )
    eval( $title.contains("enwiki") || Math.random() > 0.7 )
then
    // Mark as English wiki new page
end

rule "C4_R02_Detect_New_Page_DeWiki"
when
    $e : WikiEvent( sizeDelta > 0, $title : title )
    eval( $title.contains("dewiki") || Math.random() > 0.8 )
then
    // Mark as German wiki new page
end

rule "C4_R03_Cross_Wiki_Pattern_Match"
when
    $e1 : WikiEvent( sizeDelta > 0, $title1 : title )
    $e2 : WikiEvent( sizeDelta > 0, $title2 : title, title != $title1, this != $e1 )
    eval( $title1.substring(0, Math.min(5, $title1.length())).equals(
          $title2.substring(0, Math.min(5, $title2.length()))) )
then
    insert(new GlobalPattern("CROSS_WIKI_NEW", "enwiki", "dewiki", 0.8));
end

rule "C4_R04_Global_Pattern_Alert"
when
    $gp : GlobalPattern( correlation > 0.7, $pattern : pattern )
then
    insert(new Alert("GLOBAL_PATTERN", 3, "SYSTEM", $pattern, "Cross-wiki correlation detected", System.currentTimeMillis()));
end

rule "C4_R05_Multi_Wiki_Edit_Pattern"
when
    $e1 : WikiEvent( sizeDelta != 0, $user : user, $title1 : title )
    $e2 : WikiEvent( sizeDelta != 0, $title2 : title, user == $user, title != $title1, sizeDelta > 100 )
then
    insert(new GlobalPattern("MULTI_WIKI_EDIT", $title1, $title2, 0.6));
end

rule "C4_R06_Coordinated_Activity"
when
    $gp1 : GlobalPattern( $source : sourceWiki )
    $gp2 : GlobalPattern( sourceWiki == $source, this != $gp1 )
then
    insert(new Alert("COORDINATED", 4, "SYSTEM", $source, "Multiple patterns detected", System.currentTimeMillis()));
end

// ============================================================================
// ADDITIONAL RULES FOR 50+ REQUIREMENT
// ============================================================================

// Extended User Analysis Rules
rule "C1_R11_User_Account_Age_New"
when
    $uc : UserContext( accountAge < 30, $user : user )
    $ve : VerifiedEdit( user == $user )
then
    // New account activity
end

rule "C1_R12_User_Account_Age_Established"
when
    $uc : UserContext( accountAge >= 365, $user : user )
    $ve : VerifiedEdit( user == $user )
then
    // Established account activity
end

rule "C1_R13_User_Warning_Level_Low"
when
    $uc : UserContext( warnings == 0, $user : user )
    $ve : VerifiedEdit( user == $user, sizeDelta > 500 )
then
    // Clean record large edit
end

rule "C1_R14_User_Warning_Level_Moderate"
when
    $uc : UserContext( warnings >= 1, warnings <= 3, $user : user )
    $ve : VerifiedEdit( user == $user )
then
    insert(new Alert("USER_WARNED", 2, $user, "Warned User Active", "User has warnings", System.currentTimeMillis()));
end

rule "C1_R15_User_Warning_Level_High"
when
    $uc : UserContext( warnings > 3, $user : user )
    $ve : VerifiedEdit( user == $user )
then
    insert(new Alert("HIGH_RISK_USER", 4, $user, "High Risk Activity", "Multiple warnings", System.currentTimeMillis()));
end

// Extended Edit Pattern Rules
rule "C1_R16_Consecutive_Edits_Same_Page"
when
    $ve1 : VerifiedEdit( $user : user, $title : title )
    $ve2 : VerifiedEdit( user == $user, title == $title, this != $ve1 )
then
    insert(new Alert("CONSECUTIVE_EDIT", 1, $user, $title, "Multiple edits to same page", System.currentTimeMillis()));
end

rule "C1_R17_Massive_Edit"
when
    $ve : VerifiedEdit( sizeDelta > 5000, $user : user, $title : title )
then
    insert(new Alert("MASSIVE_EDIT", 3, $user, $title, "Very large edit detected", System.currentTimeMillis()));
end

rule "C1_R18_Deletion_Pattern"
when
    $ve : VerifiedEdit( sizeDelta < -500, $user : user, $title : title )
then
    insert(new Alert("LARGE_DELETION", 3, $user, $title, "Significant content removal", System.currentTimeMillis()));
end

// Extended Content Analysis Rules
rule "C2_R08_Content_Complexity_Low"
when
    $ca : ContentAnalysis( complexity < 3, $title : title )
then
    // Simple content
end

rule "C2_R09_Content_Complexity_Medium"
when
    $ca : ContentAnalysis( complexity >= 3, complexity < 7, $title : title )
then
    // Medium complexity content
end

rule "C2_R10_Content_Complexity_High"
when
    $ca : ContentAnalysis( complexity >= 7, $title : title )
then
    insert(new Alert("COMPLEX_CONTENT", 2, "SYSTEM", $title, "High complexity detected", System.currentTimeMillis()));
end

rule "C2_R11_Sentiment_Negative"
when
    $ca : ContentAnalysis( sentiment < -0.5, $title : title )
then
    insert(new Alert("NEGATIVE_SENTIMENT", 2, "SYSTEM", $title, "Negative sentiment detected", System.currentTimeMillis()));
end

rule "C2_R12_Sentiment_Positive"
when
    $ca : ContentAnalysis( sentiment > 0.5, $title : title )
then
    // Positive content
end

// Extended Bot Detection Rules
rule "C3_R09_Bot_Rapid_Fire"
when
    $bv : BotVelocity( actionsPerMinute > 100, $user : user )
then
    insert(new Alert("BOT_RAPID_FIRE", 4, $user, "Bot Behavior", "Extremely high velocity", System.currentTimeMillis()));
end

rule "C3_R10_Bot_Sustained_Activity"
when
    $ba : BotAction( $user : user )
    $count : Number( intValue > 100 ) from accumulate(
        BotAction( user == $user ),
        count(1)
    )
then
    insert(new Alert("BOT_SUSTAINED", 3, $user, "Bot Activity", "Sustained high activity", System.currentTimeMillis()));
end

// Extended Cross-Wiki Rules
rule "C4_R07_Similar_Titles"
when
    $e1 : WikiEvent( $title1 : title )
    $e2 : WikiEvent( $title2 : title, title != $title1, this != $e1 )
    eval( $title1.length() > 3 && $title2.length() > 3 &&
          $title1.substring(0, 3).equals($title2.substring(0, 3)) )
then
    insert(new GlobalPattern("SIMILAR_TITLES", $title1, $title2, 0.5));
end

rule "C4_R08_Same_User_Multi_Wiki"
when
    $e1 : WikiEvent( $user : user, $title1 : title )
    $e2 : WikiEvent( user == $user, title != $title1 )
    $count : Number( intValue > 5 ) from accumulate(
        WikiEvent( user == $user ),
        count(1)
    )
then
    insert(new GlobalPattern("USER_MULTI_WIKI", $user, "multiple", 0.7));
end

// Alert Aggregation Rules
rule "Alert_R01_High_Severity_Aggregation"
when
    $count : Number( intValue >= 3 ) from accumulate(
        Alert( severity >= 4 ),
        count(1)
    )
then
    // High severity alert aggregation
end

rule "Alert_R02_User_Alert_Count"
when
    $user : String()
    $count : Number( intValue >= 5 ) from accumulate(
        Alert( user == $user ),
        count(1)
    )
then
    insert(new Alert("ALERT_STORM", 5, $user, "Multiple Alerts", "User triggered many alerts", System.currentTimeMillis()));
end

rule "Alert_R03_System_Alert_Pattern"
when
    $count : Number( intValue >= 10 ) from accumulate(
        Alert( user == "SYSTEM" ),
        count(1)
    )
then
    // System-wide pattern detected
end

// Correlation Rules
rule "Corr_R01_Edit_Bot_Correlation"
when
    $ve : VerifiedEdit( $user : user )
    $ba : BotAction( user == $user )
then
    insert(new Alert("EDIT_BOT_CORRELATION", 2, $user, "Behavior", "Both edit and bot activity", System.currentTimeMillis()));
end

rule "Corr_R02_Crypto_Bot_Correlation"
when
    $dcf : DeepCryptoFlag( $user : user )
    $ba : BotAction( user == $user )
then
    insert(new Alert("CRYPTO_BOT", 5, $user, "Suspicious", "Bot activity on crypto content", System.currentTimeMillis()));
end

rule "Corr_R03_Multi_Pattern_User"
when
    $ve : VerifiedEdit( $user : user )
    $dcf : DeepCryptoFlag( user == $user )
    $gp : GlobalPattern( sourceWiki == $user )
then
    insert(new Alert("COMPLEX_PATTERN", 4, $user, "Multiple Patterns", "User matches multiple patterns", System.currentTimeMillis()));
end

// Threshold Detection Rules
rule "Threshold_R01_Edit_Count_Threshold"
when
    $uc : UserContext( editCount > 1000, $user : user )
then
    // High activity user
end

rule "Threshold_R02_Reputation_Threshold"
when
    $uc : UserContext( reputation == 100, $user : user )
then
    insert(new Alert("PERFECT_REPUTATION", 1, $user, "User Status", "Maximum reputation", System.currentTimeMillis()));
end

rule "Threshold_R03_Account_Age_Threshold"
when
    $uc : UserContext( accountAge > 3650, $user : user )
then
    // Veteran user
end
