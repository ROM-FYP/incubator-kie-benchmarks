package rules.c3;

import org.kie.benchmark.cep.wikimedia.model.WikiEvent;

// ============================================================================
// BOT ACTIVITY MONITORING PIPELINE - Automated edits (bot == true)
// ============================================================================

declare BotActivity @role(event) @expires(5s) 
    user : String; 
    action : String; 
end
declare BotProfile @role(event) @expires(5s) 
    user : String; 
    category : String; 
end
declare BotHealthCheck @role(event) @expires(5s) 
    user : String; 
    status : String; 
end
declare BotMetrics @role(event) @expires(5s) 
    user : String; 
end
declare BotReported @role(event) @expires(5s) 
    user : String; 
end

rule "Bot_Detect" salience 400
when
    $e : WikiEvent( bot == true, $u : user, $t : title )
then
    // Stage 1: Identify bot-originated edit
    insert(new BotActivity($u, "edit"));
end

rule "Bot_Categorize" salience 395
when
    $b : BotActivity( $u : user )
then
    // Stage 2: Categorize bot type based on naming conventions
    String category = $u.contains("Bot") ? "REGISTERED" : "UNVERIFIED";
    insert(new BotProfile($u, category));
    retract($b);
end

rule "Bot_HealthCheck" salience 390
when
    $b : BotProfile( $u : user, $cat : category )
then
    // Stage 3: Check if bot is operating within expected parameters
    String status = $cat.equals("REGISTERED") ? "HEALTHY" : "REVIEW_NEEDED";
    insert(new BotHealthCheck($u, status));
    retract($b);
end

rule "Bot_Metrics" salience 385
when
    $b : BotHealthCheck( $u : user )
then
    // Stage 4: Update bot activity metrics
    insert(new BotMetrics($u));
    retract($b);
end

rule "Bot_Report" salience 380
when
    $b : BotMetrics( $u : user )
then
    // Stage 5: Generate activity report
    insert(new BotReported($u));
    retract($b);
end

rule "Bot_Complete" salience 375
when
    $b : BotReported()
then
    // Stage 6: Cleanup - end of bot monitoring pipeline
    retract($b);
end
