end

rule "C07_MinorStep7" salience 794
when
    $uc : UserContext( editCount == 6, $u : user )
    $qg : QualityGrade( title == "MINOR_C", user == $u, grade == "C_step6", $s : score )
then
    String verdict = $s >= 20 ? "C_good" : "C_basic";
    modify($uc) { setEditCount(7); }
    modify($qg) { setGrade(verdict); }
end

rule "C08_MinorStep8" salience 793
when
