when
    $ec : EditClassification( type == "B_step5", $t : pageTitle )
    $qg : QualityGrade( title == "MAJOR_B", user == $t, grade == "B_step5", $s : score )
then
    int newScore = $s + 15;
    modify($ec) { setType("B_step6"); }
    modify($qg) { setGrade("B_step6"); }
    modify($qg) { setScore(newScore); }
end

rule "B07_MajorStep7" salience 894
when
    $ec : EditClassification( type == "B_step6", $t : pageTitle )
    $qg : QualityGrade( title == "MAJOR_B", user == $t, grade == "B_step6" )
then
    modify($ec) { setType("B_step7"); }
    modify($qg) { setGrade("B_step7"); }
end

rule "B08_MajorStep8" salience 893
when
    $ec : EditClassification( type == "B_step7", $t : pageTitle )
    $qg : QualityGrade( title == "MAJOR_B", user == $t, grade == "B_step7", $s : score )
then
    String verdict = $s > 50 ? "B_good" : "B_ok";
    modify($ec) { setType("B_step8"); }
    modify($qg) { setGrade(verdict); }
end

rule "B09_MajorStep9" salience 892
when
    $ec : EditClassification( type == "B_step8", $t : pageTitle )
    $qg : QualityGrade( title == "MAJOR_B", user == $t, grade == "B_good" || grade == "B_ok", $s : score )
then
