/*
 * WIKIMEDIA DEEP SEMANTIC CLUSTERING - v7
 * =====================================================================
 * 100 rules across 5 clusters (20 each)
 * Dense beta joins on every rule (2+ facts matched)
 * Cluster-specific prefixes to prevent cross-matching
 * =====================================================================
 */

package org.kie.benchmark.cep.wikimedia.rules;

import org.kie.benchmark.cep.wikimedia.model.WikiEvent;
import org.kie.benchmark.cep.wikimedia.model.UserContext;
import org.kie.benchmark.cep.wikimedia.model.EditClassification;
import org.kie.benchmark.cep.wikimedia.model.BotAction;
import org.kie.benchmark.cep.wikimedia.model.Alert;
import org.kie.benchmark.cep.wikimedia.model.QualityGrade;
import org.kie.benchmark.cep.wikimedia.model.SuspiciousActivity;

declare WikiEvent @role(event) @expires(120s) end
declare BotAction @role(event) @expires(90s) end
declare EditClassification @role(event) @expires(90s) end
declare UserContext @role(event) @expires(90s) end
declare QualityGrade @role(event) @expires(90s) end
declare SuspiciousActivity @role(event) @expires(90s) end
declare Alert @role(event) @expires(120s) end


// ============================================================================
// CLUSTER A: BOT MONITORING (20 rules, salience 1000-980)
// Entry: bot == true
// All facts use title="BOT_A" and reason="BOT" to prevent cross-cluster matching
// ============================================================================

rule "A01_BotEntry" salience 1000
when
    $e : WikiEvent( bot == true, $u : user, $size : sizeDelta )
then
    insert(new BotAction($u, "A_step1", Math.abs($size)));
    insert(new SuspiciousActivity($u, "BOT_A", "BOT", "A_step1", 1));
end

rule "A02_BotStep2" salience 999
when
    $ba : BotAction( type == "A_step1", $u : user )
    $sa : SuspiciousActivity( user == $u, reason == "BOT", status == "A_step1" )
then
    modify($ba) { setType("A_step2"); }
    modify($sa) { setStatus("A_step2"); }
end

rule "A03_BotStep3" salience 998
when
    $ba : BotAction( type == "A_step2", $u : user, $vel : velocity )
    $sa : SuspiciousActivity( user == $u, reason == "BOT", status == "A_step2" )
then
    int threat = $vel > 200 ? 3 : 1;
    modify($ba) { setType("A_step3"); }
    modify($sa) { setStatus("A_step3"); }
    modify($sa) { setRiskLevel(threat); }
end

rule "A04_BotStep4" salience 997
when
    $ba : BotAction( type == "A_step3", $u : user )
    $sa : SuspiciousActivity( user == $u, reason == "BOT", status == "A_step3", $r : riskLevel )
then
    insert(new QualityGrade("BOT_A", $u, "A_step4", -10 * $r));
    modify($ba) { setType("A_step4"); }
    modify($sa) { setStatus("A_step4"); }
end

rule "A05_BotStep5" salience 996
when
    $ba : BotAction( type == "A_step4", $u : user )
    $sa : SuspiciousActivity( user == $u, reason == "BOT", status == "A_step4" )
    $qg : QualityGrade( title == "BOT_A", user == $u, grade == "A_step4" )
then
    modify($ba) { setType("A_step5"); }
    modify($sa) { setStatus("A_step5"); }
    modify($qg) { setGrade("A_step5"); }
end

rule "A06_BotStep6" salience 995
when
    $ba : BotAction( type == "A_step5", $u : user )
    $sa : SuspiciousActivity( user == $u, reason == "BOT", status == "A_step5" )
    $qg : QualityGrade( title == "BOT_A", user == $u, grade == "A_step5", $s : score )
then
    int newScore = $s - 10;
    modify($ba) { setType("A_step6"); }
    modify($sa) { setStatus("A_step6"); }
    modify($qg) { setGrade("A_step6"); }
    modify($qg) { setScore(newScore); }
end

rule "A07_BotStep7" salience 994
when
    $ba : BotAction( type == "A_step6", $u : user )
    $sa : SuspiciousActivity( user == $u, reason == "BOT", status == "A_step6" )
    $qg : QualityGrade( title == "BOT_A", user == $u, grade == "A_step6" )
then
    modify($ba) { setType("A_step7"); }
    modify($sa) { setStatus("A_step7"); }
    modify($qg) { setGrade("A_step7"); }
end

rule "A08_BotStep8" salience 993
when
    $ba : BotAction( type == "A_step7", $u : user )
    $sa : SuspiciousActivity( user == $u, reason == "BOT", status == "A_step7", $r : riskLevel )
    $qg : QualityGrade( title == "BOT_A", user == $u, grade == "A_step7" )
then
    String action = $r >= 2 ? "A_block" : "A_allow";
    modify($ba) { setType("A_step8"); }
    modify($sa) { setStatus(action); }
    modify($qg) { setGrade("A_step8"); }
end

rule "A09_BotStep9" salience 992
when
    $ba : BotAction( type == "A_step8", $u : user )
    $sa : SuspiciousActivity( user == $u, reason == "BOT", status == "A_block" || status == "A_allow" )
    $qg : QualityGrade( title == "BOT_A", user == $u, grade == "A_step8", $s : score )
then
    int newScore = $s + 50;
    modify($ba) { setType("A_step9"); }
    modify($qg) { setGrade("A_step9"); }
    modify($qg) { setScore(newScore); }
end

rule "A10_BotStep10" salience 991
when
    $ba : BotAction( type == "A_step9", $u : user )
    $sa : SuspiciousActivity( user == $u, reason == "BOT" )
    $qg : QualityGrade( title == "BOT_A", user == $u, grade == "A_step9" )
then
    modify($ba) { setType("A_step10"); }
    modify($qg) { setGrade("A_step10"); }
end

rule "A11_BotStep11" salience 990
when
    $ba : BotAction( type == "A_step10", $u : user )
    $sa : SuspiciousActivity( user == $u, reason == "BOT" )
    $qg : QualityGrade( title == "BOT_A", user == $u, grade == "A_step10", $s : score )
then
    int newScore = $s + 20;
    modify($ba) { setType("A_step11"); }
    modify($qg) { setGrade("A_step11"); }
    modify($qg) { setScore(newScore); }
end

rule "A12_BotStep12" salience 989
when
    $ba : BotAction( type == "A_step11", $u : user )
    $sa : SuspiciousActivity( user == $u, reason == "BOT" )
    $qg : QualityGrade( title == "BOT_A", user == $u, grade == "A_step11" )
then
    modify($ba) { setType("A_step12"); }
    modify($qg) { setGrade("A_step12"); }
end

rule "A13_BotStep13" salience 988
when
    $ba : BotAction( type == "A_step12", $u : user )
    $sa : SuspiciousActivity( user == $u, reason == "BOT" )
    $qg : QualityGrade( title == "BOT_A", user == $u, grade == "A_step12", $s : score )
then
    int newScore = $s + 15;
    modify($ba) { setType("A_step13"); }
    modify($qg) { setGrade("A_step13"); }
    modify($qg) { setScore(newScore); }
end

rule "A14_BotStep14" salience 987
when
    $ba : BotAction( type == "A_step13", $u : user )
    $sa : SuspiciousActivity( user == $u, reason == "BOT" )
    $qg : QualityGrade( title == "BOT_A", user == $u, grade == "A_step13" )
then
    modify($ba) { setType("A_step14"); }
    modify($qg) { setGrade("A_step14"); }
end

rule "A15_BotStep15" salience 986
when
    $ba : BotAction( type == "A_step14", $u : user )
    $sa : SuspiciousActivity( user == $u, reason == "BOT" )
    $qg : QualityGrade( title == "BOT_A", user == $u, grade == "A_step14", $s : score )
then
    int newScore = $s + 10;
    modify($ba) { setType("A_step15"); }
    modify($qg) { setGrade("A_step15"); }
    modify($qg) { setScore(newScore); }
end

rule "A16_BotStep16" salience 985
when
    $ba : BotAction( type == "A_step15", $u : user )
    $sa : SuspiciousActivity( user == $u, reason == "BOT" )
    $qg : QualityGrade( title == "BOT_A", user == $u, grade == "A_step15" )
then
    modify($ba) { setType("A_step16"); }
    modify($qg) { setGrade("A_step16"); }
end

rule "A17_BotStep17" salience 984
when
    $ba : BotAction( type == "A_step16", $u : user )
    $sa : SuspiciousActivity( user == $u, reason == "BOT" )
    $qg : QualityGrade( title == "BOT_A", user == $u, grade == "A_step16", $s : score )
then
    int newScore = $s + 5;
    modify($ba) { setType("A_step17"); }
    modify($qg) { setGrade("A_step17"); }
    modify($qg) { setScore(newScore); }
end

rule "A18_BotStep18" salience 983
when
    $ba : BotAction( type == "A_step17", $u : user )
    $sa : SuspiciousActivity( user == $u, reason == "BOT", $st : status )
    $qg : QualityGrade( title == "BOT_A", user == $u, grade == "A_step17" )
then
    int sev = $st.equals("A_block") ? 3 : 1;
    insert(new Alert("BOT_A", sev, $u, "BOT_A", $st, System.currentTimeMillis()));
    modify($ba) { setType("A_step18"); }
    modify($qg) { setGrade("A_step18"); }
end

rule "A19_BotStep19" salience 982
when
    $alert : Alert( alertType == "BOT_A", $u : user )
    $ba : BotAction( type == "A_step18", user == $u )
    $sa : SuspiciousActivity( user == $u, reason == "BOT" )
    $qg : QualityGrade( title == "BOT_A", user == $u, grade == "A_step18" )
then
    modify($ba) { setType("A_done"); }
    modify($qg) { setGrade("A_done"); }
end

rule "A20_BotCleanup" salience 981
when
    $alert : Alert( alertType == "BOT_A", $u : user )
    $ba : BotAction( type == "A_done", user == $u )
    $sa : SuspiciousActivity( user == $u, reason == "BOT" )
    $qg : QualityGrade( title == "BOT_A", user == $u, grade == "A_done" )
then
    retract($ba);
    retract($sa);
    retract($qg);
end


// ============================================================================
// CLUSTER B: MAJOR CONTENT (20 rules, salience 900-880)
// Entry: bot == false, sizeDelta > 200
// All facts use title="MAJOR_B" to prevent cross-cluster matching
// ============================================================================

rule "B01_MajorEntry" salience 900
when
    $e : WikiEvent( bot == false, sizeDelta > 200, $u : user, $t : title, $size : sizeDelta )
then
    insert(new EditClassification($t, "B_step1", $size / 100));
    insert(new QualityGrade("MAJOR_B", $t, "B_step1", $size / 10));
end

rule "B02_MajorStep2" salience 899
when
    $ec : EditClassification( type == "B_step1", $t : pageTitle )
    $qg : QualityGrade( title == "MAJOR_B", user == $t, grade == "B_step1" )
then
    modify($ec) { setType("B_step2"); }
    modify($qg) { setGrade("B_step2"); }
end

rule "B03_MajorStep3" salience 898
when
    $ec : EditClassification( type == "B_step2", $t : pageTitle, $w : weight )
    $qg : QualityGrade( title == "MAJOR_B", user == $t, grade == "B_step2" )
then
    String cat = $w > 5 ? "B_big" : "B_med";
    modify($ec) { setType(cat); }
    modify($qg) { setGrade("B_step3"); }
end

rule "B04_MajorStep4" salience 897
when
    $ec : EditClassification( type == "B_big" || type == "B_med", $t : pageTitle )
    $qg : QualityGrade( title == "MAJOR_B", user == $t, grade == "B_step3", $s : score )
then
    int newScore = $s + 20;
    modify($ec) { setType("B_step4"); }
    modify($qg) { setGrade("B_step4"); }
    modify($qg) { setScore(newScore); }
end

rule "B05_MajorStep5" salience 896
when
    $ec : EditClassification( type == "B_step4", $t : pageTitle )
    $qg : QualityGrade( title == "MAJOR_B", user == $t, grade == "B_step4" )
then
    modify($ec) { setType("B_step5"); }
    modify($qg) { setGrade("B_step5"); }
end

