// ============================================================================
// CLUSTER E: MEDIUM CHANGES (20 rules, salience 600-580)
// Entry: bot == false, 50 < sizeDelta <= 200
// All facts use title="MED_E" to prevent cross-cluster matching
// ============================================================================

rule "E01_MediumEntry" salience 600
when
    $e : WikiEvent( bot == false, sizeDelta > 50, sizeDelta <= 200, $u : user, $t : title, $size : sizeDelta )
then
    insert(new EditClassification($t, "E_step1", $size / 50));
    insert(new QualityGrade("MED_E", $t, "E_step1", $size / 20));
end

rule "E02_MediumStep2" salience 599
when
    $ec : EditClassification( type == "E_step1", $t : pageTitle )
    $qg : QualityGrade( title == "MED_E", user == $t, grade == "E_step1" )
then
    modify($ec) { setType("E_step2"); }
    modify($qg) { setGrade("E_step2"); }
end

