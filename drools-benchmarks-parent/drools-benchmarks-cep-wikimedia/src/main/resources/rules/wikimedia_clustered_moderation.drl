then
    modify($ec) { setType("B_step16"); }
end

rule "B17_MajorStep17" salience 884
when
    $ec : EditClassification( type == "B_step16", $t : pageTitle )
    $qg : QualityGrade( title == "MAJOR_B", user == $t, $s : score, $g : grade )
then
    int sev = $g.equals("B_good") ? 1 : 2;
    insert(new Alert("MAJOR_B", sev, "sys", $t, $g, System.currentTimeMillis()));
    modify($ec) { setType("B_step17"); }
end

rule "B18_MajorStep18" salience 883
when
    $alert : Alert( alertType == "MAJOR_B", $t : title )
    $ec : EditClassification( type == "B_step17", pageTitle == $t )
    $qg : QualityGrade( title == "MAJOR_B", user == $t )
then
    modify($ec) { setType("B_step18"); }
end

rule "B19_MajorStep19" salience 882
when
    $alert : Alert( alertType == "MAJOR_B", $t : title )
    $ec : EditClassification( type == "B_step18", pageTitle == $t )
    $qg : QualityGrade( title == "MAJOR_B", user == $t )
then
    modify($ec) { setType("B_done"); }
end

rule "B20_MajorCleanup" salience 881
when
    $alert : Alert( alertType == "MAJOR_B", $t : title )
    $ec : EditClassification( type == "B_done", pageTitle == $t )
    $qg : QualityGrade( title == "MAJOR_B", user == $t )
then
    retract($ec);
    retract($qg);
end


// ============================================================================
// CLUSTER C: MINOR EDITS (20 rules, salience 800-780)
// Entry: bot == false, -50 <= sizeDelta <= 50
// All facts use title="MINOR_C" to prevent cross-cluster matching
// ============================================================================

rule "C01_MinorEntry" salience 800
when
    $e : WikiEvent( bot == false, sizeDelta >= -50, sizeDelta <= 50, $u : user )
then
    insert(new UserContext($u, 1, 1, 0, 0));
    insert(new QualityGrade("MINOR_C", $u, "C_step1", 10));
end

rule "C02_MinorStep2" salience 799
when
    $uc : UserContext( editCount == 1, $u : user )
    $qg : QualityGrade( title == "MINOR_C", user == $u, grade == "C_step1" )
then
    modify($uc) { setEditCount(2); }
    modify($qg) { setGrade("C_step2"); }
end

rule "C03_MinorStep3" salience 798
when
    $uc : UserContext( editCount == 2, $u : user )
    $qg : QualityGrade( title == "MINOR_C", user == $u, grade == "C_step2", $s : score )
then
    int newScore = $s + 5;
    modify($uc) { setEditCount(3); }
    modify($qg) { setGrade("C_step3"); }
    modify($qg) { setScore(newScore); }
end

