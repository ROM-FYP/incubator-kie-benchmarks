rule "C19_MinorStep19" salience 782
when
    $alert : Alert( alertType == "MINOR_C", $u : user )
    $uc : UserContext( editCount == 18, user == $u )
    $qg : QualityGrade( title == "MINOR_C", user == $u )
then
    modify($uc) { setEditCount(19); }
end

rule "C20_MinorCleanup" salience 781
when
    $alert : Alert( alertType == "MINOR_C", $u : user )
    $uc : UserContext( editCount == 19, user == $u )
    $qg : QualityGrade( title == "MINOR_C", user == $u )
then
    retract($uc);
    retract($qg);
end


// ============================================================================
// CLUSTER D: DELETIONS (20 rules, salience 700-680)
// Entry: bot == false, sizeDelta < -100
// All facts use title="DEL_D" and reason="DEL" to prevent cross-cluster matching
// ============================================================================

rule "D01_DeleteEntry" salience 700
when
    $e : WikiEvent( bot == false, sizeDelta < -100, $u : user, $t : title, $size : sizeDelta )
then
    insert(new SuspiciousActivity($u, $t, "DEL", "D_step1", Math.abs($size) / 100));
    insert(new QualityGrade("DEL_D", $t, "D_step1", -10));
end

rule "D02_DeleteStep2" salience 699
when
    $sa : SuspiciousActivity( reason == "DEL", status == "D_step1", $t : title )
    $qg : QualityGrade( title == "DEL_D", user == $t, grade == "D_step1" )
then
    modify($sa) { setStatus("D_step2"); }
    modify($qg) { setGrade("D_step2"); }
end

rule "D03_DeleteStep3" salience 698
when
    $sa : SuspiciousActivity( reason == "DEL", status == "D_step2", $t : title, $r : riskLevel )
    $qg : QualityGrade( title == "DEL_D", user == $t, grade == "D_step2" )
then
    String sev = $r > 3 ? "D_severe" : "D_mild";
    modify($sa) { setStatus(sev); }
    modify($qg) { setGrade("D_step3"); }
end

rule "D04_DeleteStep4" salience 697
when
    $sa : SuspiciousActivity( reason == "DEL", status == "D_severe" || status == "D_mild", $t : title )
    $qg : QualityGrade( title == "DEL_D", user == $t, grade == "D_step3", $s : score )
then
    int newScore = $s - 20;
    modify($sa) { setStatus("D_step4"); }
    modify($qg) { setGrade("D_step4"); }
    modify($qg) { setScore(newScore); }
end

