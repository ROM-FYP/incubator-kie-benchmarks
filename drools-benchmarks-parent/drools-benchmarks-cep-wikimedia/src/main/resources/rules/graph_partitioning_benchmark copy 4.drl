package org.drools.benchmark.wiki;

import org.kie.benchmark.cep.wikimedia.model.WikiEvent;
import java.util.List;
import java.util.ArrayList;

// ============================================================================
// FACT DECLARATIONS
// ============================================================================

declare WikiEvent
    @role(event)
    @expires(10s)
end

declare UserContext
    user : String @key
    reputation : int
    editCount : int
    accountAge : int
    warnings : int
end

// ----------------------------------------------------------------------------
// Specialized Clustered Events (The "Islands")
// ----------------------------------------------------------------------------

declare SmallEdit
    @role(event)
    @expires(10s)
    user : String
    title : String
    sizeDelta : int
    userReputation : int
    userWarnings : int
    timestamp : long
end

declare LargeEdit
    @role(event)
    @expires(10s)
    user : String
    title : String
    sizeDelta : int
    userReputation : int
    content : String
    timestamp : long
end

declare BotLikelyEdit
    @role(event)
    @expires(10s)
    user : String
    type : String
    velocity : int
    timestamp : long
end

declare CorrelationEvent
    @role(event)
    @expires(10s)
    key : String
    wiki : String
    timestamp : long
end

declare BotActivity
    @role(event)
    @expires(10s)
    user : String
    velocity : double
end

declare Alert
    @role(event)
    @expires(60s)
    alertType : String
    severity : int
    user : String
    title : String
    details : String
    timestamp : long
end

// ============================================================================
// CLUSTER 1: METADATA ENRICHMENT (USER INITIALIZATION)
// ============================================================================
// Objective: Only concern is creating UserContext.
// Connection: WikiEvent -> UserContext

rule "C1_Enrich_User_Context"
when
    $e : WikiEvent( sizeDelta != 0, $user : user )
    not UserContext( user == $user )
then
    int reputation = Math.abs($user.hashCode() % 100);
    int editCount = Math.abs($user.hashCode() % 5000);
    int accountAge = Math.abs($user.hashCode() % 3650);
    int warnings = Math.abs($user.hashCode() % 10);
    
    insert(new UserContext($user, reputation, editCount, accountAge, warnings));
end

// ============================================================================
// CLUSTER 2: TRAFFIC ROUTING (THE HUB BREAKER)
// ============================================================================
// Objective: Split the stream. This is the ONLY place WikiEvent joins with UserContext.
// It effectively "hides" the global hub from the rest of the network.

rule "C2_Route_Small_Edits"
when
    $e : WikiEvent( sizeDelta > 0, sizeDelta < 500, $user : user, $title : title, $diff : sizeDelta )
    $uc : UserContext( user == $user )
then
    insert(new SmallEdit($user, $title, $diff, $uc.getReputation(), $uc.getWarnings(), System.currentTimeMillis()));
end

rule "C2_Route_Large_Edits"
when
    $e : WikiEvent( sizeDelta >= 500, $user : user, $title : title, $diff : sizeDelta )
    $uc : UserContext( user == $user )
then
    // In a real app, 'content' would be extracted. Here we simulate.
    insert(new LargeEdit($user, $title, $diff, $uc.getReputation(), "content_placeholder", System.currentTimeMillis()));
end

rule "C2_Route_Bot_Activity"
when
    $e : WikiEvent( bot == true, $user : user )
then
    insert(new BotLikelyEdit($user, "bot_action", 1, System.currentTimeMillis()));
end

rule "C2_Route_Correlation_Signals"
when
    $e : WikiEvent( $title : title )
    eval( $title.startsWith("Talk:") )
then
    // Extract a key for correlation
    insert(new CorrelationEvent("talk_page", "wiki", System.currentTimeMillis()));
end

// ============================================================================
// CLUSTER 3: MICRO-EDIT VALIDATION (SmallEdit ONLY)
// ============================================================================
// Validates SmallEdit facts. No access to UserContext!

rule "C3_R01_Micro_Spam_Check"
when
    $se : SmallEdit( userWarnings > 2, sizeDelta < 10 )
then
    insert(new Alert("MICRO_SPAM", 2, $se.getUser(), $se.getTitle(), "Suspicious micro edit", System.currentTimeMillis()));
end

rule "C3_R02_Reputation_Micro_Boost"
when
    $se : SmallEdit( userReputation > 80 )
then
    // Logic to auto-approve high rep micro edits
end

rule "C3_R03_Rapid_Micro_Edits"
when
    $se1 : SmallEdit( $user : user )
    $count : Number( intValue > 5 ) from accumulate(
        $s : SmallEdit( user == $user ) over window:time(5s),
        count($s)
    )
then
    insert(new Alert("RAPID_MICRO", 3, $user, "Micro Edits", "Too many small edits", System.currentTimeMillis()));
end

rule "C3_R04_Micro_Edit_Pattern_A"
when
    $se : SmallEdit( sizeDelta == 1 )
then end

rule "C3_R05_Micro_Edit_Pattern_B"
when
    $se : SmallEdit( sizeDelta == 2 )
then end

// ============================================================================
// CLUSTER 4: MALICIOUS CONTENT DETECTION (LargeEdit ONLY)
// ============================================================================
// Validates LargeEdit facts. No access to UserContext!

rule "C4_R01_Crypto_Scan_Large"
when
    $le : LargeEdit( title.toLowerCase().contains("crypto") || title.toLowerCase().contains("bitcoin"), 
                     userReputation < 50 )
then
    insert(new Alert("CRYPTO_RISK", 4, $le.getUser(), $le.getTitle(), "Low rep crypto edit", System.currentTimeMillis()));
end

rule "C4_R02_Massive_Additions"
when
    $le : LargeEdit( sizeDelta > 5000 )
then
    insert(new Alert("MASSIVE_ADD", 2, $le.getUser(), $le.getTitle(), "Massive content addition", System.currentTimeMillis()));
end

rule "C4_R03_Keyword_Scam"
when
    $le : LargeEdit( title.toLowerCase().contains("free") && title.toLowerCase().contains("money") )
then
    insert(new Alert("SCAM_KEYWORD", 5, $le.getUser(), $le.getTitle(), "Scam keywords", System.currentTimeMillis()));
end

rule "C4_R04_Safe_Large_Edit"
when
    $le : LargeEdit( userReputation > 90 )
then
    // Auto-approve trusted large edits
end

rule "C4_R05_Complex_Content"
when
    $le : LargeEdit( sizeDelta > 1000, sizeDelta < 2000 )
then end

// ============================================================================
// CLUSTER 5: BOT BEHAVIOR ANALYTICS (BotLikelyEdit ONLY)
// ============================================================================
// Optimized window processing for bots.

rule "C5_R01_Calculate_Velocity"
when
    $b : BotLikelyEdit( $user : user )
    $count : Number() from accumulate(
        $be : BotLikelyEdit( user == $user ) over window:time(10s),
        count($be)
    )
then
    insert(new BotActivity($user, $count.doubleValue()));
end

rule "C5_R02_High_Velocity_Bot"
when
    $ba : BotActivity( velocity > 50, $user : user )
then
    insert(new Alert("BOT_HIGH_VELOCITY", 3, $user, "Bot", "High velocity detected", System.currentTimeMillis()));
end

rule "C5_R03_Extreme_Velocity_Bot"
when
    $ba : BotActivity( velocity > 100, $user : user )
then
    insert(new Alert("BOT_EXTREME", 5, $user, "Bot", "Extreme velocity", System.currentTimeMillis()));
end

rule "C5_R04_Low_Velocity_Bot"
when
    $ba : BotActivity( velocity < 10 )
then end

rule "C5_R05_Sustained_Bot_Swarm"
when
    $count : Number( intValue > 10 ) from accumulate(
        $ba : BotActivity( velocity > 20 ) over window:time(5s),
        count($ba)
    )
then
    insert(new Alert("BOT_SWARM", 4, "SYSTEM", "Swarm", "Multiple active bots", System.currentTimeMillis()));
end

// ============================================================================
// CLUSTER 6: CROSS-WIKI TEMPORAL PATTERNS (CorrelationEvent ONLY)
// ============================================================================
// Isolated temporal logic.

rule "C6_R01_Burst_Correlation"
when
    $ce1 : CorrelationEvent( $key : key )
    $ce2 : CorrelationEvent( key == $key, this != $ce1, this after[0, 2s] $ce1 )
    $count : Number( intValue > 5 ) from accumulate(
        $ce : CorrelationEvent( key == $key ) over window:time(10s),
        count($ce)
    )
then
    insert(new Alert("TEMPORAL_BURST", 3, "SYSTEM", $key, "Burst of correlation events", System.currentTimeMillis()));
end

rule "C6_R02_Slow_Drift"
when
    $ce1 : CorrelationEvent( $key : key )
    $ce2 : CorrelationEvent( key == $key, this != $ce1, this after[5s, 10s] $ce1 )
then
    // Slow drift pattern
end

rule "C6_R03_Double_Tap"
when
    $ce1 : CorrelationEvent( $key : key )
    $ce2 : CorrelationEvent( key == $key, this != $ce1, this after[0, 500ms] $ce1 )
then
    // Double tap pattern
end

// ============================================================================
// CLUSTER 7: ALERT AGGREGATION
// ============================================================================
// Sinks for all alerts.

rule "C7_R01_Global_Alert_Count"
when
    $count : Number( intValue > 10 ) from accumulate(
        $a : Alert() over window:time(10s),
        count($a)
    )
then
    // High global alert volume
end

rule "C7_R02_Severe_Alerts"
when
    $a : Alert( severity >= 5 )
then
    // Action on severe alert
end
