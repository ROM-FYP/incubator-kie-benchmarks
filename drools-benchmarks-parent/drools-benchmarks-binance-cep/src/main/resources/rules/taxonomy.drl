// ==========================================================
// G) Futures-specific dislocation(Rules 53-60)
// MarkIndexState is singleton per symbol.
// ==========================================================

rule "G53_MarkIndexDivergence_New"
  no-loop
when
  $c : RiskConfig( $sym : symbol, $med : dislocMedBps, $hi : dislocHighBps, $cr : dislocCritBps )
  $b : BestBidAsk( symbol == $sym, $bid : bid, $ask : ask )
  $m : MarketEvent( symbol == $sym, eventType == "MARK", $mark : p1, $tM : tsMs )
  $i : MarketEvent( symbol == $sym, eventType == "INDEX", $idx : p1, $tI : tsMs )
  eval( $idx > 0 && ( $bid + $ask ) > 0 && $mark > 0 )
  not MarkIndexState( symbol == $sym )
then
  double mid = ( $bid + $ask ) / 2.0;
  double mi = bps( $mark, $idx );
  double mm = bps( $mark, mid );
  String tier = tierByBps( mi, $med, $hi, $cr );
  insert(new MarkIndexState($sym, $mark, $idx, mid, mi, mm, tier, Math.max($tM, $tI)));
end

rule "G53_MarkIndexDivergence_Update"
  no-loop
when
  $c : RiskConfig( $sym : symbol, $med : dislocMedBps, $hi : dislocHighBps, $cr : dislocCritBps )
  $b : BestBidAsk( symbol == $sym, $bid : bid, $ask : ask )
  $m : MarketEvent( symbol == $sym, eventType == "MARK", $mark : p1, $tM : tsMs )
  $i : MarketEvent( symbol == $sym, eventType == "INDEX", $idx : p1, $tI : tsMs )
  eval( $idx > 0 && ( $bid + $ask ) > 0 && $mark > 0 )
  $mis : MarkIndexState( symbol == $sym )
then
  double mid = ( $bid + $ask ) / 2.0;
  double mi = bps( $mark, $idx );
  double mm = bps( $mark, mid );
  String tier = tierByBps( mi, $med, $hi, $cr );
  modify($mis) { setMarkPx($mark), setIndexPx($idx), setMidPx(mid), setMarkIndexBps(mi), setMarkMidBps(mm), setTier(tier), setTsMs(Math.max($tM, $tI)) }
end

rule "G54_ComputeMarkMidDivergence"
  no-loop
when
  $ms : MarkIndexState( $sym : symbol )
then
  insert(new RiskSignal($sym, "G54_ComputeMarkMidDivergence", "INFO", System.currentTimeMillis(), "Fired"));
end

rule "G55_DislocationPersistence"
  no-loop
when
  $c : RiskConfig( $sym : symbol, $persist : dislocPersistMs )
  $d : MarkIndexState( symbol == $sym, tier == "HIGH" || tier == "CRIT", $t : tsMs )
  eval( ( System.currentTimeMillis() - $t ) >= $persist )
then
  insert(new RiskSignal($sym, "DISLOCATION_PERSISTENCE", "HIGH", System.currentTimeMillis(), "Dislocation persisted"));
end

rule "G56_DislocationPlusThinBook"
  no-loop
when
  $d : MarkIndexState( $sym : symbol, tier == "HIGH" || tier == "CRIT" )
  $ds: DepthState( symbol == $sym, tier == "LOW" || tier == "CRIT_LOW" )
then
  insert(new RiskSignal($sym, "G56_DislocationPlusThinBook", "INFO", System.currentTimeMillis(), "Fired"));
end

