  no-loop
when
  $l : LiquidationStats( $sym : symbol, tier == "HIGH" || tier == "CRIT" )
  $d : DepthState( symbol == $sym, tier == "LOW" || tier == "CRIT_LOW" )
then
  insert(new RiskSignal($sym, "H64_LiqPlusDepthCollapse", "INFO", System.currentTimeMillis(), "Fired"));
end

