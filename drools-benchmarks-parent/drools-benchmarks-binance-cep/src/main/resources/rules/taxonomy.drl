rule "F47_VolSpike"
when
  $v1 : VolState( $sym : symbol, $t1 : tsMs, $tier1 : tier )
  $v2 : VolState( symbol == $sym, tsMs > $t1, $tier2 : tier )
  eval( ($tier1 == "LOW" && ($tier2 == "HIGH" || $tier2 == "CRIT")) || ($tier1 == "MED" && $tier2 == "CRIT") )
then
  insert(new RiskSignal($sym, "VOL_SPIKE", "WARN", $v2.tsMs, "Volatility tier spiked"));
end

rule "F48_VolPersistenceHigh"
when
  $v : VolState( $sym : symbol, tier == "HIGH" || tier == "CRIT" )
then
  insert(new RiskSignal($sym, "VOL_PERSIST", "WARN", $v.tsMs, "High volatility observed"));
end

rule "F49_TradeDrivenMove"
when
  $ts : TradeStats( $sym : symbol, tradeRateTier == "HIGH" || tradeRateTier == "CRIT" )
  $v  : VolState( symbol == $sym, tier == "HIGH" || tier == "CRIT" )
then
  insert(new RiskSignal($sym, "TRADE_DRIVEN_MOVE", "WARN", Math.max($ts.tsMs, $v.tsMs), "High trade rate with high vol"));
end

rule "F50_BookDrivenMove"
when
  $ls : RiskSignal( $sym : symbol, kind == "LIQUIDITY_STRESS" )
  $v  : VolState( symbol == $sym, tier == "HIGH" || tier == "CRIT" )
then
  insert(new RiskSignal($sym, "BOOK_DRIVEN_MOVE", "WARN", Math.max($ls.tsMs, $v.tsMs), "Liquidity stress with high vol"));
end

rule "F51_RegimeShiftToSafe"
when
  $v : VolState( $sym : symbol, tier == "HIGH" || tier == "CRIT" )
then
  insert(new RiskSignal($sym, "REGIME_SHIFT", "WARN", $v.tsMs, "Shift to high-vol regime"));
end

rule "F52_RegimeNormalizationEligibility"
when
  $v : VolState( $sym : symbol, tier == "LOW" || tier == "MED" )
then
  insert(new RiskSignal($sym, "REGIME_NORMAL", "INFO", $v.tsMs, "Normalization observed (use cooldown to recover)"));
end

// ==========================================================
//  G) Futures-specific dislocation (Rules 53-60)
//  Assumption:
//    MARK event p1=markPx
//    INDEX event p1=indexPx
//    BestBidAsk provides mid
// ==========================================================

rule "G53_ComputeMarkIndexDivergence"
when
  $c : RiskConfig( $sym : symbol, $med : dislocMedBps, $hi : dislocHighBps, $cr : dislocCritBps )
  $b : BestBidAsk( symbol == $sym, $mid : (bid+ask)/2, $tB : tsMs )
  $m : MarketEvent( symbol == $sym, eventType == "MARK", $mark : p1, $tM : tsMs )
  $i : MarketEvent( symbol == $sym, eventType == "INDEX", $idx : p1, $tI : tsMs )
  eval( $idx > 0 && $mid > 0 && $mark > 0 )
then
  double mi = bps($mark, $idx);
  double mm = bps($mark, $mid);
  String tier = tierByBps(mi, $med, $hi, $cr);
  insert(new MarkIndexState($sym, $mark, $idx, $mid, mi, mm, tier, Math.max($tM, $tI)));
end

rule "G54_ComputeMarkMidDivergence"
when
  $ms : MarkIndexState( $sym : symbol, $mm : markMidBps )
then
  if (Math.abs($mm) > 0) {
    // already available; taxonomy slot kept for separation
  }
end

rule "G55_DislocationPersistence"
when
  $c : RiskConfig( $sym : symbol, $persist : dislocPersistMs )
  $d : MarkIndexState( symbol == $sym, tier == "HIGH" || tier == "CRIT", $t : tsMs )
  not MarkIndexState( symbol == $sym, tsMs > $t, tier == "LOW" || tier == "MED" )
  eval( (System.currentTimeMillis() - $t) >= $persist )
then
  insert(new RiskSignal($sym, "DISLOCATION_PERSIST", "CRIT", System.currentTimeMillis(), "Mark-index dislocation persisted"));
end

rule "G56_DislocationPlusThinBook"
when
  $d : MarkIndexState( $sym : symbol, tier == "HIGH" || tier == "CRIT" )
  $ds: DepthState( symbol == $sym, tier == "LOW" || tier == "CRIT_LOW" )
then
  insert(new RiskSignal($sym, "SEVERE_DISLOCATION", "CRIT", Math.max($d.tsMs, $ds.tsMs), "Dislocation + thin book"));
end

rule "G57_DislocationPlusTradeBurst"
when
  $d : MarkIndexState( $sym : symbol, tier == "HIGH" || tier == "CRIT" )
  $ts: TradeStats( symbol == $sym, tradeRateTier == "HIGH" || tradeRateTier == "CRIT" )
then
  insert(new RiskSignal($sym, "STRESS_DISLOCATION", "CRIT", Math.max($d.tsMs, $ts.tsMs), "Dislocation + trade burst"));
end

rule "G58_IndexStaleButMarkMoving"
when
  $h : FeedHealth( $sym : symbol, status == "STALE_INDEX" )
  $m : MarketEvent( symbol == $sym, eventType == "MARK" )
then
  insert(new RiskSignal($sym, "INDEX_UNTRUSTED", "WARN", $m.tsMs, "Index stale while mark updates"));
end

rule "G59_MarkStaleButMarketActive"
when
  $h : FeedHealth( $sym : symbol, status == "STALE_MARK" )
  $e : MarketEvent( symbol == $sym, eventType == "DEPTH" || eventType == "TRADE" )
then
  insert(new RiskSignal($sym, "MARK_UNTRUSTED", "WARN", $e.tsMs, "Mark stale while market active"));
end

rule "G60_SuddenDivergenceReversalFlag"
when
  $d1 : MarkIndexState( $sym : symbol, $t1 : tsMs, tier == "CRIT" )
  $d2 : MarkIndexState( symbol == $sym, tsMs > $t1, tier == "LOW" || tier == "MED" )
  eval( ($d2.tsMs - $d1.tsMs) < 2000 )
then
  insert(new RiskSignal($sym, "DISLOC_REVERSAL", "WARN", $d2.tsMs, "Dislocation reversed unusually fast"));
end

// ==========================================================
//  H) Liquidation & cascade stress (Rules 61-67)
//  Assumption: LIQ event p1=notional, p2 unused; app aggregates counts into LiquidationStats
// ==========================================================

rule "H61_LiqTiering"
when
  $c : RiskConfig( $sym : symbol, $m : liqMed, $h : liqHigh, $cr : liqCrit )
  $ls: LiquidationStats( symbol == $sym, $cnt : liqCount10s )
then
  String tier = ($cnt >= $cr) ? "CRIT" : (($cnt >= $h) ? "HIGH" : (($cnt >= $m) ? "MED" : "LOW"));
  modify($ls){ setTier(tier) };
end

rule "H62_LiqBurstJump"
when
  $c : RiskConfig( $sym : symbol, $jump : liqJump )
  $l1 : LiquidationStats( $sym : symbol, $t1 : tsMs, $c1 : liqCount10s )
  $l2 : LiquidationStats( symbol == $sym, tsMs > $t1, $c2 : liqCount10s )
  eval( ($c2 - $c1) >= $jump )
then
  insert(new RiskSignal($sym, "LIQ_BURST", "WARN", $l2.tsMs, "Liquidation burst jump"));
end

rule "H63_LiqPlusVolSpike"
when
  $l : LiquidationStats( $sym : symbol, tier == "HIGH" || tier == "CRIT" )
  $v : VolState( symbol == $sym, tier == "HIGH" || tier == "CRIT" )
then
  insert(new RiskSignal($sym, "STRESS_EVENT", "CRIT", Math.max($l.tsMs, $v.tsMs), "Liquidations + vol spike"));
end

rule "H64_LiqPlusDepthCollapse"
when
  $l : LiquidationStats( $sym : symbol, tier == "HIGH" || tier == "CRIT" )
  $d : DepthState( symbol == $sym, tier == "LOW" || tier == "CRIT_LOW" )
then
  insert(new RiskSignal($sym, "CASCADE_RISK", "CRIT", Math.max($l.tsMs, $d.tsMs), "Liquidations + thin depth"));
end

rule "H65_LiqPlusDislocation"
when
  $l : LiquidationStats( $sym : symbol, tier == "HIGH" || tier == "CRIT" )
  $d : MarkIndexState( symbol == $sym, tier == "HIGH" || tier == "CRIT" )
then
  insert(new RiskSignal($sym, "SEVERE_CASCADE_RISK", "CRIT", Math.max($l.tsMs, $d.tsMs), "Liquidations + dislocation"));
end

rule "H66_CascadePersistenceEscalate"
when
  $r : RiskSignal( $sym : symbol, kind == "SEVERE_CASCADE_RISK" || kind == "CASCADE_RISK" )
then
  // Add persistence tracking in app if needed.
end

rule "H67_CascadeCooldownEligibility"
when
  $l : LiquidationStats( $sym : symbol, tier == "LOW" || tier == "MED" )
then
  insert(new RiskSignal($sym, "CASCADE_COOLDOWN", "INFO", $l.tsMs, "Liquidations cooled down"));
end

// ==========================================================
//  I) Policy engine: mode transitions & kill-switch (Rules 68-70)
// ==========================================================

rule "I68_EnterThrottled_OnSingleStressOrDegraded"
when
  $m : ModeState( $sym : symbol, mode == "NORMAL" )
  (
    FeedHealth( symbol == $sym, status == "DEGRADED" || status == "STALE_BOOK" || status == "STALE_MARK" || status == "STALE_INDEX" )
    or RiskSignal( symbol == $sym, kind == "LIQUIDITY_STRESS" || kind == "VOL_SPIKE" || kind == "DISLOC_REVERSAL" )
  )
then
  modify($m){ setMode("THROTTLED"); setLastChangeMs(System.currentTimeMillis()); setReason("single stress/degraded"); };
  insert(new RiskSignal($sym, "MODE_CHANGE", "INFO", System.currentTimeMillis(), "Mode -> THROTTLED"));
end

rule "I69_EnterSafe_OnMultipleIndependentSignals"
when
  $c : RiskConfig( $sym : symbol, $need : safeSignalsNeed )
  $m : ModeState( symbol == $sym, (mode == "NORMAL" || mode == "THROTTLED") )
  // Count distinct stress signals by kind (simple heuristic: at least N stress kinds exist)
  $cnt : Number( intValue >= $need ) from accumulate(
    RiskSignal( symbol == $sym, $k : kind,
               kind == "LIQUIDITY_STRESS" || kind == "VOL_SPIKE" || kind == "MARKET_IMPACT_RISK" ||
               kind == "STRESS_DISLOCATION" || kind == "CASCADE_RISK" || kind == "SEVERE_DISLOCATION" ),
    collectSet($k).size()
  )
then
  modify($m){ setMode("SAFE"); setLastChangeMs(System.currentTimeMillis()); setReason("multi-signal stress"); };
  insert(new RiskSignal($sym, "MODE_CHANGE", "INFO", System.currentTimeMillis(), "Mode -> SAFE"));
end

rule "I70_EnterHalted_KillSwitchLatch"
salience 10
when
  $m : ModeState( $sym : symbol, mode != "HALTED", $latched : latched )
  (
    RiskSignal( symbol == $sym, kind == "DATA_CONFLICT", severity == "CRIT" )
    or RiskSignal( symbol == $sym, kind == "SEVERE_DISLOCATION", severity == "CRIT" )
    or RiskSignal( symbol == $sym, kind == "DISLOCATION_PERSIST", severity == "CRIT" )
    or RiskSignal( symbol == $sym, kind == "SEVERE_CASCADE_RISK", severity == "CRIT" )
    or FeedHealth( symbol == $sym, status == "BOOK_UNTRUSTED" || status == "CORRUPT_BOOK" )
  )
then
  modify($m){ setMode("HALTED"); setLatched(true); setLastChangeMs(System.currentTimeMillis()); setReason("kill-switch"); };
  insert(new RiskSignal($sym, "KILL_SWITCH", "CRIT", System.currentTimeMillis(), "Mode -> HALTED (latched)"));
end

// ==========================================================
//  (Optional) Recovery policy skeleton (not counted in the 70)
// ==========================================================

rule "RECOVERY_ExitSafeToThrottled_OnNormalization"
when
  $c : RiskConfig( $sym : symbol, $cd : cooldownMs )
  $m : ModeState( symbol == $sym, mode == "SAFE", $lc : lastChangeMs )
  RiskSignal( symbol == $sym, kind == "REGIME_NORMAL", severity == "INFO" )
  eval( (System.currentTimeMillis() - $lc) > $cd )
then
  modify($m){ setMode("THROTTLED"); setLastChangeMs(System.currentTimeMillis()); setReason("cooldown passed"); };
end

rule "RECOVERY_ExitThrottledToNormal_WhenHealthy"
when
  $c : RiskConfig( $sym : symbol, $cd : cooldownMs )
  $m : ModeState( symbol == $sym, mode == "THROTTLED", $lc : lastChangeMs )
  FeedHealth( symbol == $sym, status == "OK" )
  not RiskSignal( symbol == $sym, severity == "CRIT" )
  eval( (System.currentTimeMillis() - $lc) > $cd )
then
  modify($m){ setMode("NORMAL"); setLastChangeMs(System.currentTimeMillis()); setReason("healthy"); };
end
