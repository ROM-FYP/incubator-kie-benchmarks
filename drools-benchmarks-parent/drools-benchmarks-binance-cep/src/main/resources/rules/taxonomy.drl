when
  $d : MarkIndexState( $sym : symbol, tier == "HIGH" || tier == "CRIT" )
  $ts: TradeStats( symbol == $sym, tradeRateTier == "HIGH" || tradeRateTier == "CRIT" )
then
  insert(new RiskSignal($sym, "G57_DislocationPlusTradeBurst", "INFO", System.currentTimeMillis(), "Fired"));
end

