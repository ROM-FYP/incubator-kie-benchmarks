package com.example.market_risk

import java.lang.Math
import java.util.concurrent.TimeUnit

// ==========================================================
//  Market-data-only Risk Controls / Kill-Switch — Single DRL
//  (Binance USDⓈ-M style: depth, trades, mark/index, liquidations)
//  This file is a "complete skeleton" that compiles and provides
//  70 rule slots matching the taxonomy you asked for.
//
//  Notes:
//  - Thresholds are centralized in RiskConfig (insert one per symbol tier).
//  - "Derived" facts are created from raw stream events.
//  - Replace TODO thresholds / wiring with your real ingestion fields.
// ==========================================================

// -------------------- Globals (optional) -------------------
global org.slf4j.Logger log;

// ==========================================================
//  Declarations (Events + Derived Facts + Policy Facts)
// ==========================================================

declare MarketEvent
  @role( event )
  symbol      : String
  tsMs        : long   // event time in ms
  eventType   : String // "DEPTH" | "TRADE" | "MARK" | "INDEX" | "LIQ" | "HEARTBEAT" | ...
  // payload as generic fields for single-file simplicity
  p1          : double // price / bid / mark / index / ...
  p2          : double // ask / qty / ...
  p3          : double // optional
  s1          : String // optional
end

declare FeedHealth
  symbol        : String
  status        : String // OK | DEGRADED | STALE_BOOK | STALE_TRADE | STALE_MARK | STALE_INDEX | CORRUPT_BOOK | BOOK_UNTRUSTED | FEED_OVERLOAD
  lastBookTsMs  : long
  lastTradeTsMs : long
  lastMarkTsMs  : long
  lastIndexTsMs : long
  lastHbTsMs    : long
  ooCount       : int   // out-of-order count in window
  gapCount      : int   // book gap count (if you track update IDs)
end

declare BestBidAsk
  symbol : String
  bid   : double
  ask   : double
  tsMs  : long
end

declare SpreadState
  symbol    : String
  spreadBps : double
  tier      : String // LOW | MED | HIGH | CRIT
  tsMs      : long
end

declare DepthState
  symbol   : String
  bidDepth : double
  askDepth : double
  tier     : String // HIGH | MED | LOW | CRIT_LOW
  tsMs     : long
end

declare ImbalanceState
  symbol    : String
  imbalance : double // (bidDepth-askDepth)/(bidDepth+askDepth) in [-1..1]
  tier      : String // BAL | BIASED | EXTREME
  tsMs      : long
end

declare TradeStats
  symbol        : String
  lastTradePx   : double
  lastTradeQty  : double
  tradeRate1s   : double
  tradeRateTier : String // LOW | MED | HIGH | CRIT
  tsMs          : long
end

declare VolState
  symbol    : String
  vol1s     : double
  vol10s    : double
  vol1m     : double
  tier      : String // LOW | MED | HIGH | CRIT
  tsMs      : long
end

declare MarkIndexState
  symbol         : String
  markPx         : double
  indexPx        : double
  midPx          : double
  markIndexBps   : double
  markMidBps     : double
  tier           : String // LOW | MED | HIGH | CRIT
  tsMs           : long
end

declare LiquidationStats
  symbol       : String
  liqCount10s  : int
  liqNot10s    : double
  tier         : String // LOW | MED | HIGH | CRIT
  tsMs         : long
end

declare RiskSignal
  symbol   : String
  kind     : String // DATA_CONFLICT | LIQUIDITY_STRESS | VOL_SPIKE | DISLOCATION | CASCADE_RISK | ...
  severity : String // INFO | WARN | CRIT
  tsMs     : long
  msg      : String
end

declare ModeState
  symbol      : String
  mode        : String // NORMAL | THROTTLED | SAFE | HALTED
  latched     : boolean
  lastChangeMs: long
  reason      : String
end

declare RiskConfig
  symbol        : String
  // clock
  maxFutureSkewMs : long
  maxPastSkewMs   : long

  // health
  hbTimeoutMs      : long
  bookStaleMs      : long
  tradeStaleMs     : long
  markStaleMs      : long
  indexStaleMs     : long
  maxOoBurst       : int

  // book validity
  maxJumpBpsNoTrade : double

  // spread tiers (bps)
  spreadMedBps  : double
  spreadHighBps : double
  spreadCritBps : double

  // depth tiers (absolute units — define in your own scale)
  depthHigh     : double
  depthMed      : double
  depthLow      : double
  depthCritLow  : double

  // trade rate tiers (trades/sec)
  trMed  : double
  trHigh : double
  trCrit : double

  // outlier band for trades vs mid (bps)
  tradeOutlierBps : double

  // vol tier thresholds (unitless proxy)
  volMed  : double
  volHigh : double
  volCrit : double

  // dislocation thresholds (bps)
  dislocMedBps   : double
  dislocHighBps  : double
  dislocCritBps  : double
  dislocPersistMs: long

  // liquidation tiers (count per 10s)
  liqMed   : int
  liqHigh  : int
  liqCrit  : int
  liqJump   : int  // tier jump trigger

  // mode control
  cooldownMs      : long
  safeSignalsNeed : int // how many independent stress signals to enter SAFE
end

// ==========================================================
//  Helper functions
// ==========================================================

function double bps(double a, double b) {
  if (b == 0.0) return 0.0;
  return (a / b - 1.0) * 10000.0;
}

function String tierByBps(double v, double med, double high, double crit) {
  double av = Math.abs(v);
  if (av >= crit) return "CRIT";
  if (av >= high) return "HIGH";
  if (av >= med)  return "MED";
  return "LOW";
}

function String spreadTier(double spreadBps, RiskConfig c) {
  if (spreadBps >= c.spreadCritBps) return "CRIT";
  if (spreadBps >= c.spreadHighBps) return "HIGH";
  if (spreadBps >= c.spreadMedBps)  return "MED";
  return "LOW";
}

function String depthTier(double bidDepth, double askDepth, RiskConfig c) {
  double d = Math.min(bidDepth, askDepth); // conservative
  if (d <= c.depthCritLow) return "CRIT_LOW";
  if (d <= c.depthLow)     return "LOW";
  if (d <= c.depthMed)     return "MED";
  return "HIGH";
}

function String tradeRateTier(double tr1s, RiskConfig c) {
  if (tr1s >= c.trCrit) return "CRIT";
  if (tr1s >= c.trHigh) return "HIGH";
  if (tr1s >= c.trMed)  return "MED";
  return "LOW";
}

function String volTier(double v, RiskConfig c) {
  if (v >= c.volCrit) return "CRIT";
  if (v >= c.volHigh) return "HIGH";
  if (v >= c.volMed)  return "MED";
  return "LOW";
}

function void ensureMode(String sym, long nowMs) {
  // Exists check is done by rule below; this is placeholder for readability
}

// ==========================================================
//  Bootstrap defaults (insert one RiskConfig + ModeState + FeedHealth per symbol)
// ==========================================================

// Rule 0a: Ensure ModeState exists
rule "BOOTSTRAP_ModeState"
salience 1000
when
  $c : RiskConfig( $sym : symbol )
  not ModeState( symbol == $sym )
then
  insert(new ModeState($sym, "NORMAL", false, System.currentTimeMillis(), "init"));
end

// Rule 0b: Ensure FeedHealth exists
rule "BOOTSTRAP_FeedHealth"
salience 999
when
  $c : RiskConfig( $sym : symbol )
  not FeedHealth( symbol == $sym )
then
  insert(new FeedHealth($sym, "OK", 0L, 0L, 0L, 0L, 0L, 0, 0));
end

// ==========================================================
//  A) Ingestion & schema sanity (Rules 1-8)
// ==========================================================

rule "A01_MissingRequiredFields"
when
  $e : MarketEvent( symbol == null || symbol == "" || tsMs <= 0 || eventType == null || eventType == "" )
then
  insert(new RiskSignal("(unknown)", "SCHEMA_INVALID", "WARN", System.currentTimeMillis(), "Missing required fields"));
end

rule "A02_InvalidNumerics"
when
  $e : MarketEvent( Double.isNaN(p1) || Double.isInfinite(p1) || Double.isNaN(p2) || Double.isInfinite(p2) )
then
  insert(new RiskSignal($e.symbol, "SCHEMA_INVALID", "WARN", $e.tsMs, "Invalid numeric payload"));
end

rule "A03_TimestampSkewBound"
when
  $c : RiskConfig( $sym : symbol, $f : maxFutureSkewMs, $p : maxPastSkewMs )
  $e : MarketEvent( symbol == $sym, $t : tsMs )
  eval( ($t - System.currentTimeMillis()) > $f || (System.currentTimeMillis() - $t) > $p )
then
  insert(new RiskSignal($sym, "TIME_SKEW", "WARN", $e.tsMs, "Event timestamp outside skew bounds"));
end

rule "A04_SymbolAllowlist"
when
  $c : RiskConfig( $sym : symbol )
  $e : MarketEvent( symbol != $sym )
then
  // If you run multi-symbol in same session, remove this and use a broader allowlist.
end

rule "A05_MonotonicPerStreamDetect"
when
  $h : FeedHealth( $sym : symbol )
  $e : MarketEvent( symbol == $sym, eventType == "DEPTH", $t : tsMs )
  eval( $h.lastBookTsMs > 0 && $t < $h.lastBookTsMs )
then
  modify($h){ setOoCount($h.ooCount + 1) };
  insert(new RiskSignal($sym, "OUT_OF_ORDER", "WARN", $t, "Depth timestamp regressed"));
end

rule "A06_PriceQtyPrecisionBounds"
when
  $c : RiskConfig( $sym : symbol )
  $e : MarketEvent( symbol == $sym, (eventType == "TRADE" || eventType == "DEPTH"), p1 <= 0.0 )
then
  insert(new RiskSignal($sym, "SCHEMA_INVALID", "WARN", $e.tsMs, "Non-positive price where not expected"));
end

rule "A07_DecodeErrorsQuarantine"
when
  $e : MarketEvent( eventType == "DECODE_ERROR" )
then
  insert(new RiskSignal("(unknown)", "DECODE_ERROR", "CRIT", System.currentTimeMillis(), "Malformed JSON / decode error"));
end

rule "A08_UnexpectedMessageType"
when
  $e : MarketEvent( eventType != "DEPTH" && eventType != "TRADE" && eventType != "MARK" && eventType != "INDEX" && eventType != "LIQ" && eventType != "HEARTBEAT" && eventType != "DECODE_ERROR" )
then
  insert(new RiskSignal($e.symbol, "UNKNOWN_TYPE", "WARN", $e.tsMs, "Unexpected eventType=" + $e.eventType));
end

// ==========================================================
//  B) Feed health & connectivity (Rules 9-18)
// ==========================================================

rule "B09_HeartbeatMissing"
when
  $c : RiskConfig( $sym : symbol, $hb : hbTimeoutMs )
  $h : FeedHealth( symbol == $sym, $last : lastHbTsMs )
  eval( $last > 0 && (System.currentTimeMillis() - $last) > $hb )
then
  modify($h){ setStatus("DEGRADED") };
  insert(new RiskSignal($sym, "FEED_HEALTH", "WARN", System.currentTimeMillis(), "Heartbeat timeout"));
end

rule "B10_ReconnectStorm"
when
  // Placeholder: emit MarketEvent(eventType="RECONNECT") from your client on reconnect.
  $e : MarketEvent( eventType == "RECONNECT", $sym : symbol, $t : tsMs )
then
  insert(new RiskSignal($sym, "RECONNECT", "WARN", $t, "Reconnect observed (count in app + insert aggregate fact if needed)"));
end

rule "B11_StreamSilenceButOpen"
when
  $c : RiskConfig( $sym : symbol, $hb : hbTimeoutMs )
  $h : FeedHealth( symbol == $sym, lastHbTsMs > 0 )
  // Placeholder: if you keep receiving heartbeats but no market data, flag.
then
  // Implement with a "LastAnyMarketTs" field if needed.
end

rule "B12_TradeActiveBookSilent"
when
  $c : RiskConfig( $sym : symbol, $bookStale : bookStaleMs )
  $h : FeedHealth( symbol == $sym, $lb : lastBookTsMs, $lt : lastTradeTsMs )
  eval( $lt > 0 && (System.currentTimeMillis() - $lb) > $bookStale )
then
  modify($h){ setStatus("STALE_BOOK") };
  insert(new RiskSignal($sym, "STALE_BOOK", "CRIT", System.currentTimeMillis(), "Trades active but book stale"));
end

rule "B13_BookActiveTradeSilent"
when
  $c : RiskConfig( $sym : symbol, $tradeStale : tradeStaleMs )
  $h : FeedHealth( symbol == $sym, $lb : lastBookTsMs, $lt : lastTradeTsMs )
  eval( $lb > 0 && (System.currentTimeMillis() - $lt) > $tradeStale )
then
  modify($h){ setStatus("STALE_TRADE") };
  insert(new RiskSignal($sym, "STALE_TRADE_TAPE", "WARN", System.currentTimeMillis(), "Book active but trade tape stale"));
end

rule "B14_StaleMark"
when
  $c : RiskConfig( $sym : symbol, $ms : markStaleMs )
  $h : FeedHealth( symbol == $sym, $lm : lastMarkTsMs )
  eval( $lm > 0 && (System.currentTimeMillis() - $lm) > $ms )
then
  modify($h){ setStatus("STALE_MARK") };
  insert(new RiskSignal($sym, "STALE_MARK", "WARN", System.currentTimeMillis(), "Mark price stale"));
end

rule "B15_StaleIndex"
when
  $c : RiskConfig( $sym : symbol, $is : indexStaleMs )
  $h : FeedHealth( symbol == $sym, $li : lastIndexTsMs )
  eval( $li > 0 && (System.currentTimeMillis() - $li) > $is )
then
  modify($h){ setStatus("STALE_INDEX") };
  insert(new RiskSignal($sym, "STALE_INDEX", "WARN", System.currentTimeMillis(), "Index price stale"));
end

rule "B16_LateEventRateHigh"
when
  $c : RiskConfig( $sym : symbol, $p : maxPastSkewMs )
  $e : MarketEvent( symbol == $sym, $t : tsMs )
  eval( (System.currentTimeMillis() - $t) > ($p / 2) ) // heuristic
then
  insert(new RiskSignal($sym, "LATE_EVENT", "WARN", $t, "Late event arrival"));
end

rule "B17_OutOfOrderBurst"
when
  $c : RiskConfig( $sym : symbol, $max : maxOoBurst )
  $h : FeedHealth( symbol == $sym, $oo : ooCount )
  eval( $oo >= $max )
then
  modify($h){ setStatus("DEGRADED") };
  insert(new RiskSignal($sym, "OUT_OF_ORDER_BURST", "WARN", System.currentTimeMillis(), "Out-of-order burst exceeds max"));
end

rule "B18_PersistentBookGaps"
when
  $h : FeedHealth( $sym : symbol, $g : gapCount )
  eval( $g > 0 )
then
  // If you truly track update ID gaps, promote to CORRUPT_BOOK after grace.
  // For now, just flag.
  insert(new RiskSignal($sym, "BOOK_GAPS", "WARN", System.currentTimeMillis(), "Book update gaps observed"));
end

// ==========================================================
//  Update "last seen" timestamps from events
// ==========================================================

rule "UPD_LastSeen_Heartbeat"
when
  $h : FeedHealth( $sym : symbol )
  $e : MarketEvent( symbol == $sym, eventType == "HEARTBEAT", $t : tsMs )
then
  modify($h){ setLastHbTsMs($t) };
end

rule "UPD_LastSeen_Depth"
when
  $h : FeedHealth( $sym : symbol )
  $e : MarketEvent( symbol == $sym, eventType == "DEPTH", $t : tsMs )
then
  modify($h){ setLastBookTsMs($t); setStatus("OK") };
end

rule "UPD_LastSeen_Trade"
when
  $h : FeedHealth( $sym : symbol )
  $e : MarketEvent( symbol == $sym, eventType == "TRADE", $t : tsMs )
then
  modify($h){ setLastTradeTsMs($t) };
end

rule "UPD_LastSeen_Mark"
when
  $h : FeedHealth( $sym : symbol )
  $e : MarketEvent( symbol == $sym, eventType == "MARK", $t : tsMs )
then
  modify($h){ setLastMarkTsMs($t) };
end

rule "UPD_LastSeen_Index"
when
  $h : FeedHealth( $sym : symbol )
  $e : MarketEvent( symbol == $sym, eventType == "INDEX", $t : tsMs )
then
  modify($h){ setLastIndexTsMs($t) };
end

// ==========================================================
//  C) Order book state validity (Rules 19-26)
//  Assumption: DEPTH event uses p1=bestBid, p2=bestAsk, p3=midOrUnused
// ==========================================================

rule "C19_CrossedBook"
when
  $e : MarketEvent( eventType == "DEPTH", $sym : symbol, $bid : p1, $ask : p2 )
  eval( $bid >= $ask && $bid > 0 && $ask > 0 )
then
  insert(new RiskSignal($sym, "BOOK_INVALID", "CRIT", $e.tsMs, "Crossed book bestBid>=bestAsk"));
end

rule "C20_NegativeOrZeroSpreadPersistent"
when
  $b : BestBidAsk( $sym : symbol, $bid : bid, $ask : ask )
  eval( ($ask - $bid) <= 0.0 )
then
  insert(new RiskSignal($sym, "BOOK_INVALID", "CRIT", $b.tsMs, "Non-positive spread"));
end

rule "C21_TopJumpNoTrades"
when
  $c : RiskConfig( $sym : symbol, $maxJump : maxJumpBpsNoTrade )
  $b1 : BestBidAsk( symbol == $sym, $oldMid : (bid+ask)/2, $t1 : tsMs )
  $e  : MarketEvent( symbol == $sym, eventType == "DEPTH", $bid2 : p1, $ask2 : p2, $t2 : tsMs )
  not MarketEvent( symbol == $sym, eventType == "TRADE", tsMs > $t1, tsMs <= $t2 )
  eval( $oldMid > 0 && Math.abs(bps((($bid2+$ask2)/2), $oldMid)) > $maxJump )
then
  insert(new RiskSignal($sym, "BOOK_SUSPECT", "WARN", $t2, "Mid jump without trades"));
end

rule "C22_TopSizesInvalid"
when
  // Placeholder: if you extend DEPTH to include sizes, check here.
then end

rule "C23_BookIncompletePartialDepth"
when
  // Placeholder: if you ingest partial depth levels count in s1, check.
then end

rule "C24_ExcessiveDepthUpdateRate"
when
  // Placeholder: in app, compute depth msg/sec and insert a rate fact; then gate here.
then end

rule "C25_BookAgeStale"
when
  $c : RiskConfig( $sym : symbol, $stale : bookStaleMs )
  $h : FeedHealth( symbol == $sym, $lb : lastBookTsMs )
  eval( $lb > 0 && (System.currentTimeMillis() - $lb) > $stale )
then
  insert(new RiskSignal($sym, "STALE_BOOK", "CRIT", System.currentTimeMillis(), "Book age exceeded threshold"));
end

rule "C26_BookSequenceDiscontinuityUnrecovered"
when
  $h : FeedHealth( $sym : symbol, gapCount > 0 )
then
  // Promote if you have grace period tracking.
  modify($h){ setStatus("BOOK_UNTRUSTED") };
  insert(new RiskSignal($sym, "BOOK_UNTRUSTED", "CRIT", System.currentTimeMillis(), "Book gaps not recovered"));
end

// Update BestBidAsk from DEPTH
rule "DERIVE_BestBidAsk_FromDepth"
when
  $e : MarketEvent( eventType == "DEPTH", $sym : symbol, $bid : p1, $ask : p2, $t : tsMs )
  eval( $bid > 0 && $ask > 0 )
then
  // replace previous
  delete( new BestBidAsk($sym, $bid, $ask, $t) ); // harmless no-op if not present
  insert(new BestBidAsk($sym, $bid, $ask, $t));
end

// ==========================================================
//  D) Trade tape sanity (Rules 27-32)
//  Assumption: TRADE event uses p1=price, p2=qty
// ==========================================================

rule "D27_TradePriceOutOfBandVsMid"
when
  $c : RiskConfig( $sym : symbol, $band : tradeOutlierBps )
  $b : BestBidAsk( symbol == $sym, $mid : (bid+ask)/2 )
  $t : MarketEvent( symbol == $sym, eventType == "TRADE", $px : p1, $ts : tsMs )
  eval( $mid > 0 && Math.abs(bps($px, $mid)) > $band )
then
  insert(new RiskSignal($sym, "TRADE_OUTLIER", "WARN", $ts, "Trade price outlier vs mid"));
end

rule "D28_TradeSizeOutlier"
when
  $t : MarketEvent( eventType == "TRADE", $sym : symbol, $qty : p2, $ts : tsMs )
  eval( $qty > 0 && $qty > 1e9 ) // TODO: replace with distribution-based threshold
then
  insert(new RiskSignal($sym, "TRADE_OUTLIER", "WARN", $ts, "Trade qty extreme outlier"));
end

rule "D29_TradeTimestampRegression"
when
  $h : FeedHealth( $sym : symbol, $lt : lastTradeTsMs )
  $t : MarketEvent( symbol == $sym, eventType == "TRADE", $ts : tsMs )
  eval( $lt > 0 && $ts < $lt )
then
  modify($h){ setOoCount($h.ooCount + 1) };
  insert(new RiskSignal($sym, "TRADE_STREAM_INVALID", "WARN", $ts, "Trade timestamp regressed"));
end

rule "D30_TradeRateTiering"
when
  $c : RiskConfig( $sym : symbol )
  $stats : TradeStats( symbol == $sym, $r : tradeRate1s )
then
  modify($stats){ setTradeRateTier(tradeRateTier($r, $c)) };
end

rule "D31_LargeTradeCluster"
when
  // Placeholder: you can insert a BlockTradeCluster fact from your app or a CEP accumulate.
then end

rule "D32_TradesWhileBookStale"
when
  $h : FeedHealth( $sym : symbol, status == "STALE_BOOK" || status == "BOOK_UNTRUSTED" )
  $t : MarketEvent( symbol == $sym, eventType == "TRADE", $ts : tsMs )
then
  insert(new RiskSignal($sym, "DATA_CONFLICT", "CRIT", $ts, "Trades observed while book stale/untrusted"));
end

// ==========================================================
//  E) Derived metrics: spread, depth, imbalance (Rules 33-42)
//  Assumption: You create DepthState from your app (top-N sizes).
//  If not, we derive a minimal DepthState with dummy depths.
// ==========================================================

rule "E33_SpreadComputeAndTier"
when
  $c : RiskConfig( $sym : symbol )
  $b : BestBidAsk( symbol == $sym, $bid : bid, $ask : ask, $ts : tsMs )
then
  double sp = ($ask - $bid);
  double mid = ($ask + $bid) / 2.0;
  double spBps = (mid > 0) ? (sp / mid) * 10000.0 : 0.0;
  insert(new SpreadState($sym, spBps, spreadTier(spBps, $c), $ts));
end

rule "E34_DepthTiering"
when
  $c : RiskConfig( $sym : symbol )
  $d : DepthState( symbol == $sym, $bd : bidDepth, $ad : askDepth )
then
  modify($d){ setTier(depthTier($bd, $ad, $c)) };
end

rule "E35_DepthCollapse"
when
  $d1 : DepthState( $sym : symbol, $t1 : tsMs, $tier1 : tier )
  $d2 : DepthState( symbol == $sym, tsMs > $t1, $tier2 : tier )
  eval( ($tier1 == "HIGH" && ($tier2 == "LOW" || $tier2 == "CRIT_LOW")) || ($tier1 == "MED" && $tier2 == "CRIT_LOW") )
then
  insert(new RiskSignal($sym, "DEPTH_COLLAPSE", "WARN", $d2.tsMs, "Depth tier collapsed"));
end

rule "E36_SpreadBlowout"
when
  $s1 : SpreadState( $sym : symbol, $t1 : tsMs, $tier1 : tier )
  $s2 : SpreadState( symbol == $sym, tsMs > $t1, $tier2 : tier )
  eval( ($tier1 == "LOW" && ($tier2 == "HIGH" || $tier2 == "CRIT")) || ($tier1 == "MED" && $tier2 == "CRIT") )
then
  insert(new RiskSignal($sym, "SPREAD_BLOWOUT", "WARN", $s2.tsMs, "Spread tier blowout"));
end

rule "E37_PersistentThinLiquidity"
when
  $d : DepthState( $sym : symbol, tier == "LOW" || tier == "CRIT_LOW" )
then
  // Add time persistence by inserting a "ThinLiquiditySince" fact in your app if needed.
  insert(new RiskSignal($sym, "THIN_LIQUIDITY", "WARN", $d.tsMs, "Thin liquidity observed"));
end

rule "E38_ImbalanceComputeTier"
when
  $d : DepthState( $sym : symbol, $bd : bidDepth, $ad : askDepth, $ts : tsMs )
  eval( ($bd + $ad) > 0 )
then
  double im = ($bd - $ad) / ($bd + $ad);
  String tier = (Math.abs(im) < 0.2) ? "BAL" : (Math.abs(im) < 0.6 ? "BIASED" : "EXTREME");
  insert(new ImbalanceState($sym, im, tier, $ts));
end

rule "E39_ImbalancePersistence"
when
  $i : ImbalanceState( $sym : symbol, tier == "EXTREME" )
then
  insert(new RiskSignal($sym, "IMBALANCE_PERSIST", "WARN", $i.tsMs, "Extreme imbalance observed"));
end

rule "E40_ImbalanceFlipFlop"
when
  $i1 : ImbalanceState( $sym : symbol, $t1 : tsMs, $v1 : imbalance )
  $i2 : ImbalanceState( symbol == $sym, tsMs > $t1, $v2 : imbalance )
  eval( ($v1 > 0.3 && $v2 < -0.3) || ($v1 < -0.3 && $v2 > 0.3) )
then
  insert(new RiskSignal($sym, "IMBALANCE_FLIPFLOP", "WARN", $i2.tsMs, "Imbalance sign flip"));
end

rule "E41_LiquidityStressCombine"
when
  $s : SpreadState( $sym : symbol, tier == "HIGH" || tier == "CRIT" )
  $d : DepthState( symbol == $sym, tier == "LOW" || tier == "CRIT_LOW" )
then
  insert(new RiskSignal($sym, "LIQUIDITY_STRESS", "WARN", Math.max($s.tsMs, $d.tsMs), "Spread high & depth low"));
end

rule "E42_MarketImpactRiskCombine"
when
  $ls : RiskSignal( $sym : symbol, kind == "LIQUIDITY_STRESS" )
  $ts : TradeStats( symbol == $sym, tradeRateTier == "HIGH" || tradeRateTier == "CRIT" )
then
  insert(new RiskSignal($sym, "MARKET_IMPACT_RISK", "WARN", Math.max($ls.tsMs, $ts.tsMs), "Liquidity stress + high trade rate"));
end

