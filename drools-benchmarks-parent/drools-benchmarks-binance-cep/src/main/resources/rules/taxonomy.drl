// ==========================================================
// H) Liquidation & cascade stress(Rules 61-67)
// ==========================================================

// ---- Sliding-window liquidation count (feeds H61_LiqTiering) ----
rule "UPD_LiqCount10s"
  no-loop
when
  $ls : LiquidationStats( $sym : symbol )
  $cnt : Number() from accumulate(
    $e : MarketEvent( symbol == $sym, eventType == "LIQ" ) over window:time( 10s ),
    count( $e )
  )
  $not : Number() from accumulate(
    $e2 : MarketEvent( symbol == $sym, eventType == "LIQ" ) over window:time( 10s ),
    sum( $e2.getP2() )
  )
then
  modify($ls) { setLiqCount10s($cnt.intValue()), setLiqNot10s($not.doubleValue()), setTsMs(drools.getClockCurrentTime()) }
end

rule "H61_LiqTiering"
  no-loop
when
  $c : RiskConfig( $sym : symbol, $m : liqMed, $h : liqHigh, $cr : liqCrit )
  $ls: LiquidationStats( symbol == $sym, $cnt : liqCount10s )
then
  String tier = ( $cnt >= $cr ) ? "CRIT" : ( ( $cnt >= $h ) ? "HIGH" : ( ( $cnt >= $m ) ? "MED" : "LOW" ) );
  modify($ls) { setTier(tier) }
end

rule "H62_LiqBurstJump"
  no-loop
when
  $c : RiskConfig( $sym : symbol, $jump : liqJump )
  $ls : LiquidationStats( symbol == $sym, $cnt : liqCount10s )
  eval( $cnt >= $jump )
then
  insert(new RiskSignal($sym, "H62_LiqBurstJump", "INFO", System.currentTimeMillis(), "Fired"));
end

rule "H63_LiqPlusVolSpike"
  no-loop
when
  $l : LiquidationStats( $sym : symbol, tier == "HIGH" || tier == "CRIT" )
  $v : VolState( symbol == $sym, tier == "HIGH" || tier == "CRIT" )
then
  insert(new RiskSignal($sym, "H63_LiqPlusVolSpike", "INFO", System.currentTimeMillis(), "Fired"));
end

